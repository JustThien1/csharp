@page "/route-tracking"
@using MudBlazor
@using TourGuideHCM.Admin.Models
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<div class="d-flex align-center mb-6">
    <MudText Typo="Typo.h4" Class="font-weight-bold">🚶 Tuyến di chuyển theo thiết bị</MudText>
    <MudSpacer />
    <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.Shield">Dữ liệu ẩn danh</MudChip>
</div>

<!-- Chọn thiết bị -->
<MudPaper Class="pa-5 mb-5" Elevation="3" Style="border-radius:16px;">
    <div class="d-flex align-center justify-space-between mb-4">
        <MudText Typo="Typo.h6">📱 Chọn thiết bị để xem tuyến đường</MudText>
        <div class="d-flex align-center" style="gap:8px;">
            <MudTooltip Text="Tạo dữ liệu route giả cho 5 thiết bị để test UI">
                <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.DataObject"
                           OnClick="SeedDemoAsync" Disabled="@seeding">
                    @(seeding ? "Đang tạo..." : "Tạo dữ liệu demo")
                </MudButton>
            </MudTooltip>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="LoadDevicesAsync" Disabled="@loadingDevices">
                Làm mới danh sách
            </MudButton>
        </div>
    </div>

    <!-- Filter theo ngày + search -->
    <div class="d-flex align-center mb-3" style="gap:12px; flex-wrap:wrap;">
        <MudTextField @bind-Value="searchText"
                      Placeholder="Tìm theo tên thiết bị hoặc DeviceId..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Style="flex:1; min-width:280px;" />

        <MudSelect T="int" @bind-Value="filterDays" Label="Thời gian" Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:160px;">
            <MudSelectItem Value="1">Hôm nay</MudSelectItem>
            <MudSelectItem Value="7">7 ngày qua</MudSelectItem>
            <MudSelectItem Value="30">30 ngày qua</MudSelectItem>
            <MudSelectItem Value="0">Tất cả</MudSelectItem>
        </MudSelect>

        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.FilterAlt"
                   OnClick="LoadDevicesAsync">
            Áp dụng
        </MudButton>
    </div>

    @if (loadingDevices)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-3" />
    }
    else if (!devices.Any())
    {
        <MudAlert Severity="Severity.Info" Class="my-3">
            <strong>Chưa có thiết bị nào có dữ liệu tuyến đường.</strong><br />
            Nhấn <strong>"Tạo dữ liệu demo"</strong> ở trên để test UI, hoặc cho app MAUI chạy một thời gian
            để thu thập vị trí thật.
        </MudAlert>
    }
    else
    {
        <div style="max-height:280px; overflow-y:auto; border:1px solid #eee; border-radius:8px;">
            <MudTable T="DeviceRouteItem" Items="@filteredDevices" Hover="true" Dense="true"
                      OnRowClick="@(EventCallback.Factory.Create<TableRowClickEventArgs<DeviceRouteItem>>(this, OnDeviceRowClick))"
                      Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Thiết bị</MudTh>
                    <MudTh>Nền tảng</MudTh>
                    <MudTh Style="text-align:center;">Số điểm</MudTh>
                    <MudTh>Lần cuối hoạt động</MudTh>
                    <MudTh Style="width:80px;"></MudTh>
                </HeaderContent>
                <RowTemplate Context="dev">
                    <MudTd>
                        <MudText Typo="Typo.body2" Class="font-weight-medium">@dev.DeviceName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family:monospace;">
                            @dev.DeviceIdShort
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <div class="d-flex align-center" style="gap:4px;">
                            <MudIcon Icon="@GetPlatformIcon(dev.Platform)" Size="Size.Small" Color="@GetPlatformColor(dev.Platform)" />
                            <MudText Typo="Typo.body2">@dev.Platform</MudText>
                        </div>
                    </MudTd>
                    <MudTd Style="text-align:center;">
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@dev.PointCount</MudChip>
                    </MudTd>
                    <MudTd>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @dev.LastSeen.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </MudText>
                    </MudTd>
                    <MudTd>
                        <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Text"
                                   EndIcon="@Icons.Material.Filled.ArrowForward"
                                   OnClick="@(() => LoadRouteAsync(dev.DeviceId))">
                            Xem
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>
    }

    @if (routeData != null)
    {
        <MudGrid Spacing="3" Class="mt-4">
            <MudItem xs="12" sm="3">
                <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-radius:12px; background:#e3f2fd;">
                    <MudIcon Icon="@Icons.Material.Filled.PhoneAndroid" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mt-1">@routeData.DeviceName</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family:monospace;">@routeData.DeviceIdShort</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-radius:12px; background:#e8f5e9;">
                    <MudIcon Icon="@Icons.Material.Filled.Route" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h5" Class="font-weight-bold mt-1">@routeData.TotalKm km</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Tổng quãng đường</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-radius:12px; background:#fff3e0;">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Warning" Size="Size.Large" />
                    <MudText Typo="Typo.h5" Class="font-weight-bold mt-1">@routeData.Points.Count</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Điểm đã qua</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-radius:12px; background:#fce4ec;">
                    <MudIcon Icon="@Icons.Material.Filled.AccessTime" Color="Color.Error" Size="Size.Large" />
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mt-1">
                        @(routeData.Points.Any() ? routeData.Points.Last().Timestamp.ToLocalTime().ToString("dd/MM HH:mm") : "-")
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Lần cuối hoạt động</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudPaper>

<MudGrid Spacing="4">
    <!-- Map -->
    <MudItem xs="12" md="8">
        <MudPaper Class="pa-0" Elevation="3" Style="border-radius:16px; overflow:hidden;">
            <div class="pa-4 d-flex align-center" style="border-bottom:1px solid #eee;">
                <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Primary" Class="mr-2" />
                <MudText Typo="Typo.h6">
                    @(routeData != null ? $"Tuyến đường: {routeData.DeviceName}" : "Bản đồ tuyến di chuyển")
                </MudText>
                <MudSpacer />
                <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="mr-1">🔴 @allPois.Count POI</MudChip>
                <MudChip T="string" Size="Size.Small" Color="Color.Primary">🔵 @(routeData?.Points.Count ?? 0) điểm</MudChip>
            </div>

            <div id="routeMap" style="height:520px; width:100%;"></div>

            <div class="pa-3 d-flex align-center" style="gap:20px; border-top:1px solid #eee; flex-wrap:wrap;">
                <div class="d-flex align-center" style="gap:6px;">
                    <div style="width:16px;height:4px;background:#1976D2;border-radius:2px;"></div>
                    <MudText Typo="Typo.caption">Tuyến di chuyển</MudText>
                </div>
                <div class="d-flex align-center" style="gap:6px;">
                    <div style="width:10px;height:10px;background:#1976D2;border-radius:50%;"></div>
                    <MudText Typo="Typo.caption">Điểm đã qua (xanh)</MudText>
                </div>
                <div class="d-flex align-center" style="gap:6px;">
                    <div style="width:10px;height:10px;background:#E53935;border-radius:50%;"></div>
                    <MudText Typo="Typo.caption">Địa điểm POI (đỏ)</MudText>
                </div>
                <div class="d-flex align-center" style="gap:6px;">
                    <div style="width:10px;height:10px;background:#FF6F00;border-radius:50%;"></div>
                    <MudText Typo="Typo.caption">Xuất phát / Kết thúc</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>

    <!-- Danh sách điểm + POI -->
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-0" Elevation="3" Style="border-radius:16px; overflow:hidden; max-height:630px;">
            <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" PanelClass="pa-0">

                <!-- Tab: Điểm đã đi qua -->
                <MudTabPanel Text="📍 Điểm đã qua" Icon="@Icons.Material.Filled.Route">
                    <div style="max-height:540px; overflow-y:auto; padding:16px;">
                        @{
                            var points = routeData?.Points ?? new List<RoutePointDto>();
                        }
                        @if (!points.Any())
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Chọn thiết bị ở bảng trên để xem tuyến đường
                            </MudAlert>
                        }
                        else
                        {
                            <MudTimeline TimelinePosition="TimelinePosition.Left" Dense="true">
                                @foreach (var (pt, i) in points.Select((p, i) => (p, i)))
                                {
                                    var color = i == 0 ? Color.Success
                                              : i == points.Count - 1 ? Color.Error
                                              : Color.Primary;
                                    var nearbyPoi = allPois
                                        .Select(poi => new { poi, dist = Haversine(pt.Lat, pt.Lng, poi.Lat, poi.Lng) })
                                        .Where(x => x.dist < 0.3)
                                        .OrderBy(x => x.dist)
                                        .FirstOrDefault()?.poi;

                                    <MudTimelineItem Color="@color" Size="Size.Small">
                                        <ItemContent>
                                            <MudPaper Class="pa-2 mb-1 cursor-pointer"
                                                      Elevation="1" Style="border-radius:8px;"
                                                      @onclick="() => ZoomToPoint(pt.Lat, pt.Lng)">
                                                <MudText Typo="Typo.body2" Class="font-weight-medium">
                                                    @(i == 0 ? "🟢 Xuất phát" : i == points.Count - 1 ? "🔴 Kết thúc" : $"🔵 Điểm {i + 1}")
                                                </MudText>
                                                @if (nearbyPoi != null)
                                                {
                                                    <div class="d-flex align-center mt-1" style="gap:4px;">
                                                        <MudIcon Icon="@Icons.Material.Filled.Place" Color="Color.Error" Size="Size.Small" />
                                                        <MudText Typo="Typo.caption" Style="color:#E53935; font-weight:600;">@nearbyPoi.Name</MudText>
                                                    </div>
                                                }
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    🕐 @pt.Timestamp.ToLocalTime().ToString("HH:mm dd/MM")
                                                </MudText>
                                                @if (i > 0)
                                                {
                                                    var dist = Haversine(points[i - 1].Lat, points[i - 1].Lng, pt.Lat, pt.Lng);
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        +@(dist < 1 ? $"{dist * 1000:F0}m" : $"{dist:F2}km")
                                                    </MudText>
                                                }
                                            </MudPaper>
                                        </ItemContent>
                                    </MudTimelineItem>
                                }
                            </MudTimeline>
                        }
                    </div>
                </MudTabPanel>

                <!-- Tab: POI -->
                <MudTabPanel Text="🏛️ POI" Icon="@Icons.Material.Filled.Place">
                    <div style="max-height:540px; overflow-y:auto; padding:16px;">
                        @foreach (var poi in allPois)
                        {
                            <MudPaper Class="pa-3 mb-2 cursor-pointer" Elevation="1"
                                      Style="border-radius:10px;"
                                      @onclick="() => ZoomToPoint(poi.Lat, poi.Lng)">
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Place"
                                             Color="Color.Error" Size="Size.Small" Class="mr-2" />
                                    <div>
                                        <MudText Typo="Typo.subtitle2">@poi.Name</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@poi.Address</MudText>
                                    </div>
                                </div>
                            </MudPaper>
                        }
                    </div>
                </MudTabPanel>

            </MudTabs>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private List<DeviceRouteItem> devices = new();
    private List<PoiDto> allPois = new();
    private RouteDeviceDto? routeData;

    private string searchText = "";
    private int filterDays = 30;
    private bool loadingDevices = false;
    private bool seeding = false;
    private bool mapInitialized = false;

    private IEnumerable<DeviceRouteItem> filteredDevices =>
        string.IsNullOrWhiteSpace(searchText)
            ? devices
            : devices.Where(d =>
                d.DeviceName.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                d.DeviceId.Contains(searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try { allPois = await Http.GetFromJsonAsync<List<PoiDto>>("api/poi") ?? new(); }
        catch { allPois = new(); }

        await LoadDevicesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initRouteMap", 10.7769, 106.7009, 13);
            mapInitialized = true;
            await RefreshMap();
        }
    }

    private async Task LoadDevicesAsync()
    {
        loadingDevices = true;
        try
        {
            var url = filterDays > 0
                ? $"api/route/devices?days={filterDays}"
                : "api/route/devices";
            devices = await Http.GetFromJsonAsync<List<DeviceRouteItem>>(url) ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải danh sách thiết bị: {ex.Message}", Severity.Warning);
            devices = new();
        }
        finally
        {
            loadingDevices = false;
            StateHasChanged();
        }
    }

    private async Task LoadRouteAsync(string deviceId)
    {
        try
        {
            var url = filterDays > 0
                ? $"api/route/by-device?deviceId={Uri.EscapeDataString(deviceId)}&days={filterDays}"
                : $"api/route/by-device?deviceId={Uri.EscapeDataString(deviceId)}";

            var response = await Http.GetAsync(url);
            if (response.IsSuccessStatusCode)
            {
                routeData = await response.Content.ReadFromJsonAsync<RouteDeviceDto>();
                await RefreshMap();
                Snackbar.Add(routeData?.Points.Any() == true
                    ? $"✅ Hiển thị {routeData.Points.Count} điểm của {routeData.DeviceName}"
                    : "Thiết bị này chưa có tuyến đường", Severity.Success);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                routeData = null;
                await RefreshMap();
                Snackbar.Add("Thiết bị này chưa có dữ liệu tuyến đường", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnDeviceRowClick(TableRowClickEventArgs<DeviceRouteItem> e)
    {
        if (e.Item != null) await LoadRouteAsync(e.Item.DeviceId);
    }

    private async Task SeedDemoAsync()
    {
        seeding = true;
        StateHasChanged();
        try
        {
            var res = await Http.PostAsync("api/route/seed-demo", null);
            if (res.IsSuccessStatusCode)
            {
                Snackbar.Add("✅ Đã tạo dữ liệu demo cho 5 thiết bị", Severity.Success);
                await LoadDevicesAsync();
            }
            else
            {
                Snackbar.Add("❌ Không tạo được dữ liệu demo", Severity.Error);
            }
        }
        finally
        {
            seeding = false;
            StateHasChanged();
        }
    }

    private async Task RefreshMap()
    {
        if (!mapInitialized) return;
        var routePoints = routeData?.Points.Select(p => new { p.Lat, p.Lng }).ToList();
        var poiPoints = allPois.Select(p => new { p.Lat, p.Lng, p.Name }).ToList();
        await JS.InvokeVoidAsync("updateRouteMap", routePoints, poiPoints);
    }

    private async Task ZoomToPoint(double lat, double lng)
    {
        await JS.InvokeVoidAsync("zoomRouteMap", lat, lng, 17);
    }

    private static double Haversine(double lat1, double lng1, double lat2, double lng2)
    {
        const double R = 6371;
        var dLat = (lat2 - lat1) * Math.PI / 180;
        var dLng = (lng2 - lng1) * Math.PI / 180;
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2)
              + Math.Cos(lat1 * Math.PI / 180) * Math.Cos(lat2 * Math.PI / 180)
              * Math.Sin(dLng / 2) * Math.Sin(dLng / 2);
        return R * 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
    }

    private string GetPlatformIcon(string platform) => platform?.ToLower() switch
    {
        "android" => Icons.Material.Filled.Android,
        "ios" => Icons.Material.Filled.PhoneIphone,
        "windows" => Icons.Material.Filled.Computer,
        _ => Icons.Material.Filled.DeviceUnknown
    };

    private Color GetPlatformColor(string platform) => platform?.ToLower() switch
    {
        "android" => Color.Success,
        "ios" => Color.Info,
        "windows" => Color.Primary,
        _ => Color.Default
    };

    // DTOs
    public class DeviceRouteItem
    {
        public string DeviceId { get; set; } = "";
        public string DeviceIdShort { get; set; } = "";
        public string DeviceName { get; set; } = "";
        public string Platform { get; set; } = "";
        public string UserName { get; set; } = "";
        public int PointCount { get; set; }
        public DateTime FirstSeen { get; set; }
        public DateTime LastSeen { get; set; }
    }

    public class RoutePointDto
    {
        public double Lat { get; set; }
        public double Lng { get; set; }
        public DateTime Timestamp { get; set; }
    }

    public class RouteDeviceDto
    {
        public string DeviceId { get; set; } = "";
        public string DeviceIdShort { get; set; } = "";
        public string DeviceName { get; set; } = "";
        public string Platform { get; set; } = "";
        public string UserName { get; set; } = "";
        public List<RoutePointDto> Points { get; set; } = new();
        public double TotalKm { get; set; }
    }

    public class PoiDto { public int Id { get; set; } public string Name { get; set; } = ""; public string Address { get; set; } = ""; public double Lat { get; set; } public double Lng { get; set; } }
}
