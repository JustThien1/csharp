@page "/route-tracking"
@using MudBlazor
@using TourGuideHCM.Admin.Models
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<div class="d-flex align-center mb-6">
    <MudText Typo="Typo.h4" Class="font-weight-bold">🚶 Tuyến di chuyển người dùng</MudText>
    <MudSpacer />
    <MudChip Color="Color.Success" Icon="@Icons.Material.Filled.Shield">Dữ liệu ẩn danh</MudChip>
</div>

<!-- Search theo SĐT -->
<MudPaper Class="pa-5 mb-5" Elevation="3" Style="border-radius:16px;">
    <MudText Typo="Typo.h6" Class="mb-4">🔍 Tìm tuyến đường theo số điện thoại</MudText>
    <div class="d-flex align-center" style="gap:16px;">
        <MudTextField @bind-Value="searchPhone"
                      Label="Số điện thoại người dùng"
                      Placeholder="VD: 0901234567"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Phone"
                      Variant="Variant.Outlined"
                      Style="max-width:360px;"
                      OnKeyUp="@OnPhoneKeyUp" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Search"
                   OnClick="SearchUser" Disabled="@searching">
            @(searching ? "Đang tìm..." : "Tìm kiếm")
        </MudButton>
        @if (routeData != null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Clear"
                       OnClick="ClearSearch">Xóa</MudButton>
        }
    </div>

    @if (notFound)
    {
        <MudAlert Severity="Severity.Warning" Class="mt-3" Dense="true">
            Không tìm thấy người dùng với số ĐT "@searchPhone"
        </MudAlert>
    }

    @if (routeData != null)
    {
        <MudGrid Spacing="3" Class="mt-4">
            <MudItem xs="12" sm="3">
                <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-radius:12px; background:#e3f2fd;">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mt-1">@routeData.FullName</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@routeData.Phone</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-radius:12px; background:#e8f5e9;">
                    <MudIcon Icon="@Icons.Material.Filled.Route" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h5" Class="font-weight-bold mt-1">@routeData.TotalKm km</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Tổng quãng đường</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-radius:12px; background:#fff3e0;">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Warning" Size="Size.Large" />
                    <MudText Typo="Typo.h5" Class="font-weight-bold mt-1">@routeData.Points.Count</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Điểm đã qua</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-radius:12px; background:#fce4ec;">
                    <MudIcon Icon="@Icons.Material.Filled.AccessTime" Color="Color.Error" Size="Size.Large" />
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold mt-1">
                        @(routeData.Points.Any() ? routeData.Points.Last().Timestamp.ToLocalTime().ToString("dd/MM HH:mm") : "-")
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Lần cuối hoạt động</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudPaper>

<MudGrid Spacing="4">
    <!-- Map -->
    <MudItem xs="12" md="8">
        <MudPaper Class="pa-0" Elevation="3" Style="border-radius:16px; overflow:hidden;">
            <div class="pa-4 d-flex align-center" style="border-bottom:1px solid #eee;">
                <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Primary" Class="mr-2" />
                <MudText Typo="Typo.h6">
                    @(routeData != null ? $"Tuyến đường: {routeData.FullName}" : "Bản đồ tuyến di chuyển")
                </MudText>
                <MudSpacer />
                <MudChip Size="Size.Small" Color="Color.Error" Class="mr-1">🔴 @allPois.Count POI</MudChip>
                <MudChip Size="Size.Small" Color="Color.Primary">🔵 @(routeData?.Points.Count ?? 0) điểm</MudChip>
            </div>

            <!-- Leaflet map container -->
            <div id="routeMap" style="height:520px; width:100%;"></div>

            <!-- Chú thích -->
            <div class="pa-3 d-flex align-center" style="gap:20px; border-top:1px solid #eee; flex-wrap:wrap;">
                <div class="d-flex align-center" style="gap:6px;">
                    <div style="width:16px;height:4px;background:#1976D2;border-radius:2px;"></div>
                    <MudText Typo="Typo.caption">Tuyến di chuyển</MudText>
                </div>
                <div class="d-flex align-center" style="gap:6px;">
                    <div style="width:10px;height:10px;background:#1976D2;border-radius:50%;"></div>
                    <MudText Typo="Typo.caption">Điểm đã qua (xanh)</MudText>
                </div>
                <div class="d-flex align-center" style="gap:6px;">
                    <div style="width:10px;height:10px;background:#E53935;border-radius:50%;"></div>
                    <MudText Typo="Typo.caption">Địa điểm POI (đỏ)</MudText>
                </div>
                <div class="d-flex align-center" style="gap:6px;">
                    <div style="width:10px;height:10px;background:#FF6F00;border-radius:50%;"></div>
                    <MudText Typo="Typo.caption">Xuất phát / Kết thúc</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>

    <!-- Danh sách điểm + POI -->
    <MudItem xs="12" md="4">
        <MudPaper Class="pa-0" Elevation="3" Style="border-radius:16px; overflow:hidden; max-height:630px;">
            <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" PanelClass="pa-0">

                <!-- Tab: Điểm đã đi qua -->
                <MudTabPanel Text="📍 Điểm đã qua" Icon="@Icons.Material.Filled.Route">
                    <div style="max-height:540px; overflow-y:auto; padding:16px;">
                        @{
                            var points = routeData?.Points ?? new List<RoutePointDto>();
                        }
                        @if (!points.Any())
                        {
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Tìm kiếm người dùng để xem tuyến đường
                            </MudAlert>
                        }
                        else
                        {
                            <MudTimeline TimelinePosition="TimelinePosition.Left" Dense="true">
                                @foreach (var (pt, i) in points.Select((p, i) => (p, i)))
                                {
                                    var color = i == 0 ? Color.Success
                                              : i == points.Count - 1 ? Color.Error
                                              : Color.Primary;
                                    var nearbyPoi = allPois
                                        .Select(poi => new { poi, dist = Haversine(pt.Lat, pt.Lng, poi.Lat, poi.Lng) })
                                        .Where(x => x.dist < 0.3)
                                        .OrderBy(x => x.dist)
                                        .FirstOrDefault()?.poi;

                                    <MudTimelineItem Color="@color" Size="Size.Small">
                                        <ItemContent>
                                            <MudPaper Class="pa-2 mb-1 cursor-pointer"
                                                      Elevation="1" Style="border-radius:8px;"
                                                      @onclick="() => ZoomToPoint(pt.Lat, pt.Lng)">
                                                <MudText Typo="Typo.body2" Class="font-weight-medium">
                                                    @(i == 0 ? "🟢 Xuất phát" : i == points.Count - 1 ? "🔴 Kết thúc" : $"🔵 Điểm {i + 1}")
                                                </MudText>
                                                @if (nearbyPoi != null)
                                                {
                                                    <div class="d-flex align-center mt-1" style="gap:4px;">
                                                        <MudIcon Icon="@Icons.Material.Filled.Place" Color="Color.Error" Size="Size.Small" />
                                                        <MudText Typo="Typo.caption" Style="color:#E53935; font-weight:600;">@nearbyPoi.Name</MudText>
                                                    </div>
                                                }
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    🕐 @pt.Timestamp.ToLocalTime().ToString("HH:mm dd/MM")
                                                </MudText>
                                                @if (i > 0)
                                                {
                                                    var dist = Haversine(points[i - 1].Lat, points[i - 1].Lng, pt.Lat, pt.Lng);
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        +@(dist < 1 ? $"{dist * 1000:F0}m" : $"{dist:F2}km")
                                                    </MudText>
                                                }
                                            </MudPaper>
                                        </ItemContent>
                                    </MudTimelineItem>
                                }
                            </MudTimeline>
                        }
                    </div>
                </MudTabPanel>

                <!-- Tab: POI -->
                <MudTabPanel Text="🏛️ POI" Icon="@Icons.Material.Filled.Place">
                    <div style="max-height:540px; overflow-y:auto; padding:16px;">
                        @foreach (var poi in allPois)
                        {
                            <MudPaper Class="pa-3 mb-2 cursor-pointer" Elevation="1"
                                      Style="border-radius:10px;"
                                      @onclick="() => ZoomToPoint(poi.Lat, poi.Lng)">
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Place"
                                             Color="Color.Error" Size="Size.Small" Class="mr-2" />
                                    <div>
                                        <MudText Typo="Typo.subtitle2">@poi.Name</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@poi.Address</MudText>
                                    </div>
                                </div>
                            </MudPaper>
                        }
                    </div>
                </MudTabPanel>

            </MudTabs>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private string searchPhone = "";
    private bool searching = false;
    private bool notFound = false;
    private RouteUserDto? routeData;
    private List<PoiDto> allPois = new();
    private bool mapInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        try { allPois = await Http.GetFromJsonAsync<List<PoiDto>>("api/poi") ?? new(); }
        catch { allPois = new(); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initRouteMap", 10.7769, 106.7009, 13);
            mapInitialized = true;
            await RefreshMap();
        }
    }

    private async Task RefreshMap()
    {
        if (!mapInitialized) return;
        var routePoints = routeData?.Points.Select(p => new { p.Lat, p.Lng }).ToList();
        var poiPoints = allPois.Select(p => new { p.Lat, p.Lng, p.Name }).ToList();
        await JS.InvokeVoidAsync("updateRouteMap", routePoints, poiPoints);
    }

    private async Task ZoomToPoint(double lat, double lng)
    {
        await JS.InvokeVoidAsync("zoomRouteMap", lat, lng, 17);
    }

    private async Task OnPhoneKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchUser();
    }

    private async Task SearchUser()
    {
        if (string.IsNullOrWhiteSpace(searchPhone)) return;
        searching = true; notFound = false; routeData = null;
        try
        {
            var response = await Http.GetAsync($"api/route/user?phone={Uri.EscapeDataString(searchPhone.Trim())}");
            if (response.IsSuccessStatusCode)
            {
                routeData = await response.Content.ReadFromJsonAsync<RouteUserDto>();
                await RefreshMap();
                Snackbar.Add(routeData?.Points.Any() == true
                    ? $"✅ {routeData.Points.Count} điểm của {routeData.FullName}"
                    : "Chưa có dữ liệu tuyến đường", Severity.Success);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
                notFound = true;
        }
        catch (Exception ex) { Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error); }
        finally { searching = false; }
    }

    private async Task ClearSearch()
    {
        searchPhone = ""; routeData = null; notFound = false;
        await RefreshMap();
    }

    private static double Haversine(double lat1, double lng1, double lat2, double lng2)
    {
        const double R = 6371;
        var dLat = (lat2 - lat1) * Math.PI / 180;
        var dLng = (lng2 - lng1) * Math.PI / 180;
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2)
              + Math.Cos(lat1 * Math.PI / 180) * Math.Cos(lat2 * Math.PI / 180)
              * Math.Sin(dLng / 2) * Math.Sin(dLng / 2);
        return R * 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
    }

    public class RoutePointDto { public double Lat { get; set; } public double Lng { get; set; } public DateTime Timestamp { get; set; } }
    public class RouteUserDto { public int UserId { get; set; } public string FullName { get; set; } = ""; public string Phone { get; set; } = ""; public List<RoutePointDto> Points { get; set; } = new(); public double TotalKm { get; set; } }
    public class PoiDto { public int Id { get; set; } public string Name { get; set; } = ""; public string Address { get; set; } = ""; public double Lat { get; set; } public double Lng { get; set; } }
}
