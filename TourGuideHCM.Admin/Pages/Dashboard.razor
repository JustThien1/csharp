@page "/"
@page "/dashboard"
@using MudBlazor
@using TourGuideHCM.Admin.Services
@using TourGuideHCM.Admin.Models
@inject AnalyticsService AnalyticsService
@inject PlaybackService PlaybackService

<div class="d-flex align-center mb-6">
    <MudText Typo="Typo.h4" Class="font-weight-bold">📊 Dashboard Analytics</MudText>
    <MudSpacer />
    <MudButton OnClick="Refresh" Variant="Variant.Outlined" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Refresh">Làm mới</MudButton>
</div>

@if (loading)
{
    <MudGrid Spacing="4">
        @for (int i = 0; i < 4; i++)
        {
            <MudItem xs="12" md="3"><MudSkeleton Height="120px" /></MudItem>
        }
    </MudGrid>
}
else
{
    <!-- KPI Cards -->
    <MudGrid Spacing="4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5" Elevation="3" Style="background:linear-gradient(135deg,#667eea,#764ba2);color:white;border-radius:16px;">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Large" />
                    <div class="ml-4">
                        <MudText Typo="Typo.body2" Style="opacity:.8">Tổng POI</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-black">@data.TotalPoi</MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5" Elevation="3" Style="background:linear-gradient(135deg,#11998e,#38ef7d);color:white;border-radius:16px;">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Large" />
                    <div class="ml-4">
                        <MudText Typo="Typo.body2" Style="opacity:.8">Người dùng</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-black">@data.TotalUsers</MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5" Elevation="3" Style="background:linear-gradient(135deg,#f093fb,#f5576c);color:white;border-radius:16px;">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Large" />
                    <div class="ml-4">
                        <MudText Typo="Typo.body2" Style="opacity:.8">Top POI</MudText>
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@data.TopPoi</MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-5" Elevation="3" Style="background:linear-gradient(135deg,#4facfe,#00f2fe);color:white;border-radius:16px;">
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Timer" Size="Size.Large" />
                    <div class="ml-4">
                        <MudText Typo="Typo.body2" Style="opacity:.8">TB thời gian nghe</MudText>
                        <MudText Typo="Typo.h4" Class="font-weight-black">@data.AvgTime<span style="font-size:16px">s</span></MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="4" Class="mt-4">
        <!-- Biểu đồ lượt nghe -->
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-6" Elevation="3" Style="border-radius:16px;">
                <MudText Typo="Typo.h6" Class="mb-4">📈 Lượt nghe theo ngày trong tuần</MudText>
                <MudChart ChartType="ChartType.Bar"
                          Labels="@labels"
                          Datasets="@datasets"
                          Width="100%" Height="300px" />
            </MudPaper>
        </MudItem>

        <!-- Top POI -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-6" Elevation="3" Style="border-radius:16px; height:100%;">
                <MudText Typo="Typo.h6" Class="mb-4">🔥 Top địa điểm</MudText>
                <MudList Dense="true">
                    @foreach (var (item, i) in data.TopPois.OrderByDescending(x => x.Count).Take(5).Select((p, i) => (p, i)))
                    {
                        <MudListItem Class="px-0">
                            <div class="d-flex align-center justify-space-between">
                                <div class="d-flex align-center">
                                    <MudAvatar Size="Size.Small" Style="@($"background:{GetRankColor(i)};color:white;margin-right:12px;font-size:12px;")">
                                        @(i + 1)
                                    </MudAvatar>
                                    <MudText Typo="Typo.body2">@item.Name</MudText>
                                </div>
                                <MudChip Size="Size.Small" Color="Color.Primary">@item.Count lượt</MudChip>
                            </div>
                        </MudListItem>
                        <MudProgressLinear Value="@GetPercent(item.Count)" Color="Color.Primary" Rounded="true" Class="mb-2" Size="Size.Small" />
                    }
                    @if (!data.TopPois.Any())
                    {
                        <MudText Color="Color.Secondary" Typo="Typo.body2">Chưa có dữ liệu — người dùng app sẽ tạo dữ liệu khi nghe POI</MudText>
                    }
                </MudList>
            </MudPaper>
        </MudItem>

        <!-- Lịch sử gần nhất -->
        <MudItem xs="12">
            <MudPaper Class="pa-6" Elevation="3" Style="border-radius:16px;">
                <MudText Typo="Typo.h6" Class="mb-4">📜 Lịch sử nghe gần nhất (từ app)</MudText>
                <MudTable Items="@recentHistory" Dense="true" Hover="true" Bordered="false" Elevation="0">
                    <HeaderContent>
                        <MudTh>Người dùng</MudTh>
                        <MudTh>Địa điểm</MudTh>
                        <MudTh>Thời gian</MudTh>
                        <MudTh>Thời lượng</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudChip Size="Size.Small" Icon="@Icons.Material.Filled.Person">@context.User</MudChip></MudTd>
                        <MudTd>@context.Poi</MudTd>
                        <MudTd>@context.Time.ToLocalTime().ToString("dd/MM HH:mm")</MudTd>
                        <MudTd>@(context.Duration.HasValue ? $"{context.Duration:F0}s" : "-")</MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-4" Color="Color.Secondary">Chưa có lịch sử — dữ liệu được tạo khi người dùng nghe POI trong app</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    bool loading = true;
    DashboardDto data = new();
    List<PlaybackHistoryDto> recentHistory = new();
    string[] labels = { "T2", "T3", "T4", "T5", "T6", "T7", "CN" };
    List<ChartSeries> datasets = new();

    protected override async Task OnInitializedAsync() => await LoadDashboard();

    private async Task LoadDashboard()
    {
        loading = true;
        try
        {
            data = await AnalyticsService.GetDashboard() ?? new();
            recentHistory = (await PlaybackService.GetHistoryAsync()).Take(5).ToList();

            var views = data.DailyViews?.Length == 7
                ? data.DailyViews.Select(x => (double)x).ToArray()
                : new double[] { 12, 19, 25, 18, 30, 22, 15 };

            datasets = new List<ChartSeries>
            {
                new() { Name = "Lượt nghe", Data = views }
            };
        }
        catch { data = new(); }
        finally { loading = false; }
    }

    private async Task Refresh() => await LoadDashboard();

    private string GetRankColor(int i) => i switch
    {
        0 => "#FFD700",
        1 => "#C0C0C0",
        2 => "#CD7F32",
        _ => "#1976D2"
    };

    private double GetPercent(int count)
    {
        var max = data.TopPois.Any() ? data.TopPois.Max(x => x.Count) : 1;
        return max == 0 ? 0 : (double)count / max * 100;
    }
}
