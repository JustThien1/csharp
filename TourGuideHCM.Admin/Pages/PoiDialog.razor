@using TourGuideHCM.Admin.Models
@using TourGuideHCM.Admin.Services
@using MudBlazor

@inject PoiService Service
@inject ISnackbar Snackbar   // Thêm để thông báo lỗi

<MudDialog MaxWidth="MaxWidth.Small" FullWidth="true">

    <DialogContent>
        <MudForm @ref="form">

            <MudTextField Label="Tên"
                          @bind-Value="model.Name"
                          Required="true" />

            <MudTextField Label="Mô tả"
                          @bind-Value="model.Description"
                          Lines="3" />

            <MudTextField Label="Image URL"
                          @bind-Value="model.ImageUrl" />

            <MudNumericField Label="Latitude"
                             @bind-Value="model.Lat" />

            <MudNumericField Label="Longitude"
                             @bind-Value="model.Lng" />

            <!-- PREVIEW IMAGE -->
            @if (!string.IsNullOrWhiteSpace(model.ImageUrl))
            {
                <img src="@model.ImageUrl"
                     style="width:100%; margin-top:10px; border-radius:8px"
                     onerror="this.style.display='none'" />
            }

        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Save"
                   Color="Color.Primary"
                   Variant="Variant.Filled">
            💾 Lưu
        </MudButton>

        <MudButton OnClick="Cancel"
                   Variant="Variant.Outlined">
            Hủy
        </MudButton>
    </DialogActions>

</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;   // ← SỬA Ở ĐÂY

    [Parameter] public PoiDto Poi { get; set; } = new();

    private MudForm form = default!;
    private PoiDto model = new();

    protected override void OnInitialized()
    {
        model = new PoiDto
        {
            Id = Poi.Id,
            Name = Poi.Name,
            Description = Poi.Description,
            ImageUrl = Poi.ImageUrl,
            Lat = Poi.Lat,
            Lng = Poi.Lng
        };
    }

    private async Task Save()
    {
        await form.Validate();
        if (!form.IsValid)
        {
            Snackbar.Add("Vui lòng kiểm tra lại thông tin!", Severity.Warning);
            return;
        }

        bool success = model.Id == 0
            ? await Service.Create(model)
            : await Service.Update(model);

        if (success)
            MudDialog.Close(DialogResult.Ok(true));
        else
            Snackbar.Add("Lưu thất bại!", Severity.Error);
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}