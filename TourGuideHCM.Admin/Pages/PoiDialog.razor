@using MudBlazor
@using TourGuideHCM.Admin.Models
@using TourGuideHCM.Admin.Services

@inject PoiService Service
@inject ISnackbar Snackbar

<MudDialog MaxWidth="MaxWidth.Medium" FullWidth="true">
    <DialogContent>
        <MudForm @ref="form">

            <MudTextField Label="Tên POI *"
                          @bind-Value="model.Name"
                          Required="true"
                          RequiredError="Tên POI không được để trống" />

            <MudTextField Label="Mô tả"
                          @bind-Value="model.Description"
                          Lines="3" />

            <MudTextField Label="Địa chỉ"
                          @bind-Value="model.Address" />

            <!-- Chọn Category -->
            <MudSelect T="int" Label="Danh mục *"
                       @bind-Value="model.CategoryId"
                       Required="true">
                <MudSelectItem T="int" Value="1">Di tích lịch sử</MudSelectItem>
                <MudSelectItem T="int" Value="2">Kiến trúc Pháp</MudSelectItem>
                <MudSelectItem T="int" Value="3">Ẩm thực</MudSelectItem>
                <MudSelectItem T="int" Value="4">Mua sắm & Giải trí</MudSelectItem>
            </MudSelect>

            <MudTextField Label="Image URL"
                          @bind-Value="model.ImageUrl" />

            <MudNumericField Label="Latitude *"
                             @bind-Value="model.Lat"
                             Required="true" />

            <MudNumericField Label="Longitude *"
                             @bind-Value="model.Lng"
                             Required="true" />

            <!-- Preview Image -->
            @if (!string.IsNullOrWhiteSpace(model.ImageUrl))
            {
                <img src="@model.ImageUrl"
                     style="width:100%; margin-top:10px; border-radius:8px"
                     onerror="this.style.display='none'" />
            }

        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Hủy</MudButton>
        <MudButton OnClick="Save" Color="Color.Primary" Variant="Variant.Filled">
            💾 Lưu
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public PoiDto Poi { get; set; } = new();

    private MudForm form = default!;
    private PoiDto model = new();

    protected override void OnInitialized()
    {
        model = new PoiDto
        {
            Id = Poi.Id,
            Name = Poi.Name,
            Description = Poi.Description,
            Address = Poi.Address,
            ImageUrl = Poi.ImageUrl,
            Lat = Poi.Lat,
            Lng = Poi.Lng,
            CategoryId = Poi.CategoryId > 0 ? Poi.CategoryId : 1
        };
    }

    private async Task Save()
    {
        await form.Validate();
        if (!form.IsValid)
        {
            Snackbar.Add("Vui lòng nhập đầy đủ thông tin bắt buộc!", Severity.Warning);
            return;
        }

        bool success = model.Id == 0
            ? await Service.Create(model)
            : await Service.Update(model);

        if (success)
        {
            Snackbar.Add(model.Id == 0 ? "✅ Thêm POI thành công!" : "✅ Cập nhật POI thành công!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            Snackbar.Add("❌ Lưu thất bại! Vui lòng kiểm tra lại.", Severity.Error);
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}