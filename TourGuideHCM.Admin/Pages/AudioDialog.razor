@using MudBlazor
@using TourGuideHCM.Admin.Models
@using TourGuideHCM.Admin.Services
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Forms

@inject AudioService AudioService
@inject ISnackbar Snackbar

<MudDialog MaxWidth="MaxWidth.Medium" FullWidth="true">
    <DialogContent>
        <MudForm @ref="form">

            <!-- Chọn POI -->
            <MudSelect T="int" Label="Chọn POI *" @bind-Value="model.PoiId"
                       Required="true" RequiredError="Vui lòng chọn POI" Class="mb-4">
                @foreach (var poi in Pois)
                {
                    <MudSelectItem T="int" Value="@poi.Id">@poi.Name</MudSelectItem>
                }
            </MudSelect>

            <!-- Ngôn ngữ -->
            <MudSelect T="string" Label="Ngôn ngữ *" @bind-Value="model.Language"
                       Required="true" RequiredError="Vui lòng chọn ngôn ngữ" Class="mb-4">
                <MudSelectItem T="string" Value="@("vi")">Tiếng Việt</MudSelectItem>
                <MudSelectItem T="string" Value="@("en")">English</MudSelectItem>
                <MudSelectItem T="string" Value="@("zh")">Tiếng Trung</MudSelectItem>
                <MudSelectItem T="string" Value="@("ko")">Tiếng Hàn</MudSelectItem>
            </MudSelect>

            <!-- Upload Audio - ĐÃ SỬA -->
            <MudText Typo="Typo.body2" Class="mb-1 mud-text-secondary">
                Chọn file audio (.mp3, .wav, .m4a, .ogg) - Tối đa 10MB
            </MudText>

            <MudFileUpload T="IBrowserFile"
                           Context="fileInput"
                           FilesChanged="OnFileSelected"
                           Accept=".mp3,.wav,.m4a,.ogg"
                           MaxFiles="1"
                           Class="mb-4">

                <ButtonTemplate>
                    <MudButton HtmlTag="label"
                               for="@fileInput"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               Disabled="@uploading"
                               FullWidth="true">
                        @if (uploading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Đang upload...</span>
                        }
                        else
                        {
                            <span>Chọn file audio</span>
                        }
                    </MudButton>
                </ButtonTemplate>
            </MudFileUpload>

            <!-- Preview Audio -->
            @if (!string.IsNullOrEmpty(model.AudioUrl))
            {
                <MudPaper Elevation="0" Class="pa-3 mb-4" Style="background:#f5f5f5; border-radius:8px;">
                    <MudText Typo="Typo.caption" Class="mb-1">Xem trước audio:</MudText>
                    <audio src="@model.AudioUrl" controls style="width:100%;"></audio>
                </MudPaper>
            }

            <!-- Thời lượng -->
            <MudNumericField T="int" Label="Thời lượng (giây) *"
                             @bind-Value="model.DurationSeconds"
                             Required="true" RequiredError="Vui lòng nhập thời lượng"
                             Min="0" Class="mb-4" />

            <!-- Mô tả -->
            <MudTextField T="string" Label="Mô tả"
                          @bind-Value="model.Description" Lines="3" Class="mb-4" />

            <!-- Kích hoạt -->
            <MudSwitch T="bool" @bind-Value="model.IsActive"
                       Label="Kích hoạt" Color="Color.Success" />

        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Hủy</MudButton>
        <MudButton OnClick="Save" Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@(uploading || string.IsNullOrEmpty(model.AudioUrl))">
            Lưu
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public AudioDto Audio { get; set; } = new();
    [Parameter] public List<PoiDto> Pois { get; set; } = new();

    private MudForm form = default!;
    private AudioDto model = new();
    private bool uploading = false;

    protected override void OnInitialized()
    {
        model = new AudioDto
        {
            Id = Audio.Id,
            PoiId = Audio.PoiId,
            Language = string.IsNullOrEmpty(Audio.Language) ? "vi" : Audio.Language,
            AudioUrl = Audio.AudioUrl,
            DurationSeconds = Audio.DurationSeconds,
            Description = Audio.Description,
            IsActive = Audio.IsActive
        };
    }

    private async Task OnFileSelected(IBrowserFile? file)
    {
        if (file is null) return;

        if (file.Size > 10 * 1024 * 1024)
        {
            Snackbar.Add("File quá lớn! Tối đa 10MB.", Severity.Error);
            return;
        }

        uploading = true;
        StateHasChanged();

        try
        {
            var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
            fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType ?? "audio/mpeg");
            content.Add(fileContent, "file", file.Name);

            var (success, url) = await AudioService.UploadAudioAsync(content);

            if (success && !string.IsNullOrEmpty(url))
            {
                model.AudioUrl = url.Trim('"');
                Snackbar.Add("✅ Upload audio thành công!", Severity.Success);
            }
            else
            {
                Snackbar.Add("❌ Upload thất bại!", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi upload: {ex.Message}", Severity.Error);
        }
        finally
        {
            uploading = false;
            StateHasChanged();
        }
    }

    private async Task Save()
    {
        await form.Validate();
        if (!form.IsValid) return;

        if (string.IsNullOrEmpty(model.AudioUrl))
        {
            Snackbar.Add("Vui lòng upload file audio trước!", Severity.Warning);
            return;
        }

        if (model.Id == 0)
            await AudioService.CreateAsync(model);
        else
            await AudioService.UpdateAsync(model);

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}