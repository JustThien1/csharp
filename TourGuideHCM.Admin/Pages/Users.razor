@page "/users"

@using MudBlazor
@using TourGuideHCM.Admin.Models
@using TourGuideHCM.Admin.Services

@inject UserService UserService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">👥 Quản lý Người dùng</MudText>

<div class="d-flex justify-space-between align-center mb-4">
    <MudTextField @bind-Value="search"
                  Placeholder="Tìm theo tên, email hoặc số điện thoại..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Style="min-width: 420px;" />

    <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="NewUser" StartIcon="@Icons.Material.Filled.PersonAdd">
        ➕ Thêm người dùng mới
    </MudButton>
</div>

<MudTable Items="@filteredUsers" Hover="true" Dense="true" Bordered="true" Loading="@loading">
    <HeaderContent>
        <MudTh>ID</MudTh>
        <MudTh>Họ tên</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Số điện thoại</MudTh>
        <MudTh>Vai trò</MudTh>
        <MudTh>Lượt nghe</MudTh>
        <MudTh>Trạng thái</MudTh>
        <MudTh>Hành động</MudTh>
    </HeaderContent>
    <RowTemplate Context="user">
        <MudTd>@user.Id</MudTd>
        <MudTd>@user.FullName</MudTd>
        <MudTd>@user.Email</MudTd>
        <MudTd>
            @if (!string.IsNullOrWhiteSpace(user.Phone))
            {
                <div class="d-flex align-center" style="gap:4px;">
                    <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Color="Color.Secondary" />
                    <MudText Typo="Typo.body2">@user.Phone</MudText>
                </div>
            }
            else
            {
                <MudText Color="Color.Secondary">-</MudText>
            }
        </MudTd>
        <MudTd>
            <MudChip Color="@(user.Role == "Admin" ? Color.Error : Color.Info)">@user.Role</MudChip>
        </MudTd>
        <MudTd>@user.TotalListens</MudTd>
        <MudTd>
            <MudSwitch Value="@user.IsActive"
                       Color="Color.Success"
                       ValueChanged="@((bool v) => ToggleActive(user, v))"
                       title="@(user.IsActive ? "Khóa tài khoản" : "Mở khóa tài khoản")" />
        </MudTd>
        <MudTd>
            <MudButton Size="Size.Small" Color="Color.Warning" OnClick="() => EditUser(user)">✏️ Sửa</MudButton>
            <MudButton Size="Size.Small" Color="Color.Error" OnClick="() => DeleteUser(user.Id)">🗑 Xóa</MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<UserDto> users = new();
    private string search = "";
    private bool loading = true;

    private IEnumerable<UserDto> filteredUsers =>
        users.Where(u => string.IsNullOrWhiteSpace(search) ||
                         u.FullName.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                         u.Email.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                         (u.Phone ?? "").Contains(search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        loading = true;
        StateHasChanged();                    // ← Quan trọng: cập nhật UI khi đang loading

        try
        {
            users = await UserService.GetAllAsync() ?? new List<UserDto>();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi tải danh sách người dùng: {ex.Message}", Severity.Error);
            users = new List<UserDto>();
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task NewUser()
    {
        var dialog = await DialogService.ShowAsync<UserDialog>("Thêm người dùng mới");
        var result = await dialog.Result;
        if (!result.Canceled)
            await LoadUsers();
    }

    private async Task EditUser(UserDto user)
    {
        var parameters = new DialogParameters { ["User"] = user };
        var dialog = await DialogService.ShowAsync<UserDialog>("Sửa người dùng", parameters);
        var result = await dialog.Result;
        if (!result.Canceled)
            await LoadUsers();
    }

    private async Task DeleteUser(int id)
    {
        bool? confirm = await DialogService.ShowMessageBox(
            "Xác nhận xóa",
            "Bạn có chắc muốn xóa người dùng này? Hành động này không thể hoàn tác.",
            yesText: "Xóa", cancelText: "Hủy");

        if (confirm == true)
        {
            var success = await UserService.DeleteAsync(id);
            if (success)
            {
                Snackbar.Add("Xóa người dùng thành công!", Severity.Success);
                await LoadUsers();
            }
            else
            {
                Snackbar.Add("Xóa thất bại! Có thể người dùng không tồn tại.", Severity.Error);
            }
        }
    }

    private async Task ToggleActive(UserDto user, bool newValue)
    {
        var success = await UserService.ToggleActiveAsync(user.Id);
        if (success)
        {
            user.IsActive = newValue;
            Snackbar.Add(newValue ? $"Đã mở khóa {user.FullName}" : $"Đã khóa {user.FullName}", Severity.Success);
        }
        else
        {
            Snackbar.Add("Cập nhật trạng thái thất bại!", Severity.Error);
        }
    }
}