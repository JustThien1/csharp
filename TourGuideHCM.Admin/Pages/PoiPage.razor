@page "/poi"

@using TourGuideHCM.Admin.Models
@using TourGuideHCM.Admin.Services
@using MudBlazor

@inject PoiService Service
@inject IDialogService DialogService

<MudText Typo="Typo.h4" Class="mb-2">📍 POI Admin</MudText>

<MudTextField @bind-Value="search"
              Placeholder="Tìm kiếm..."
              Adornment="Adornment.Start"
              AdornmentIcon="@Icons.Material.Filled.Search"
              Class="mb-3" />

<MudButton Color="Color.Primary"
           Variant="Variant.Filled"
           OnClick="NewPoi"
           Class="mb-4">
    ➕ Thêm POI
</MudButton>

<MudTable Items="@filteredPois" Hover="true" Bordered="true" Dense="true">

    <HeaderContent>
        <MudTh>Ảnh</MudTh>
        <MudTh>Tên</MudTh>
        <MudTh>Mô tả</MudTh>
        <MudTh>Action</MudTh>
    </HeaderContent>

    <RowTemplate Context="poi">

        <!-- IMAGE -->
        <MudTd>
            <img src="@poi.ImageUrl"
                 width="100"
                 style="border-radius:8px"
                 onerror="this.src='https://via.placeholder.com/100'" />
        </MudTd>

        <!-- NAME -->
        <MudTd>@poi.Name</MudTd>

        <!-- DESC -->
        <MudTd style="max-width:250px; overflow:hidden; text-overflow:ellipsis">
            @poi.Description
        </MudTd>

        <!-- ACTION -->
        <MudTd>
            <MudButton Size="Size.Small"
                       Color="Color.Warning"
                       OnClick="() => Edit(poi)">
                ✏️
            </MudButton>

            <MudButton Size="Size.Small"
                       Color="Color.Error"
                       OnClick="() => Delete(poi.Id)">
                🗑
            </MudButton>
        </MudTd>

    </RowTemplate>

</MudTable>

@code {

    List<PoiDto> pois = new();   // ✅ FIX MODEL
    string search = "";

    IEnumerable<PoiDto> filteredPois =>
        pois.Where(p => string.IsNullOrWhiteSpace(search) ||
                        p.Name.Contains(search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    async Task Load()
    {
        pois = await Service.GetAll() ?? new();
    }

    async Task NewPoi()
    {
        var dialog = DialogService.Show<PoiDialog>("Thêm POI");
        var result = await dialog.Result;

        if (!result.Canceled)   // ✅ FIX
            await Load();
    }

    async Task Edit(PoiDto poi)
    {
        var parameters = new DialogParameters
        {
            ["Poi"] = poi
        };

        var dialog = DialogService.Show<PoiDialog>("Sửa POI", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)   // ✅ FIX
            await Load();
    }

    async Task Delete(int id)
    {
        bool? confirm = await DialogService.ShowMessageBox(
            "Xác nhận",
            "Bạn có chắc muốn xóa POI này?",
            yesText: "Xóa",
            cancelText: "Hủy");

        if (confirm == true)
        {
            await Service.Delete(id);
            await Load();
        }
    }
}