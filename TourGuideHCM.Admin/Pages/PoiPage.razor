@page "/poi"

@using MudBlazor
@using TourGuideHCM.Admin.Models
@using TourGuideHCM.Admin.Services

@inject PoiService Service
@inject IDialogService DialogService

<MudText Typo="Typo.h4" Class="mb-4">📍 Quản lý POI</MudText>

<MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="NewPoi" Class="mb-4">
    ➕ Thêm POI mới
</MudButton>

<MudTable Items="@filteredPois" Hover="true" Dense="true" Bordered="true" Loading="@loading">
    <HeaderContent>
        <MudTh>ID</MudTh>
        <MudTh>Tên địa điểm</MudTh>
        <MudTh>Vị trí</MudTh>
        <MudTh>Bán kính</MudTh>
        <MudTh>Audio</MudTh>
        <MudTh>Hành động</MudTh>
    </HeaderContent>
    <RowTemplate Context="poi">
        <MudTd>@poi.Id</MudTd>
        <MudTd>@poi.Name</MudTd>
        <MudTd>
            @poi.Lat, @poi.Lng
        </MudTd>
        <MudTd>500m</MudTd>   <!-- Bạn có thể thêm trường Radius vào PoiDto sau -->
        <MudTd>
            <MudChip Color="Color.Info" Size="Size.Small">Có audio</MudChip>
        </MudTd>
        <MudTd>
            <MudButton Size="Size.Small" Color="Color.Warning" OnClick="() => Edit(poi)">✏️</MudButton>
            <MudButton Size="Size.Small" Color="Color.Error" OnClick="() => Delete(poi.Id)">🗑</MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    List<PoiDto> pois = new();
    string search = "";
    bool loading = true;

    IEnumerable<PoiDto> filteredPois => pois;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    async Task Load()
    {
        loading = true;
        pois = await Service.GetAll() ?? new();
        loading = false;
    }

    async Task NewPoi() { /* giữ nguyên như cũ */ }
    async Task Edit(PoiDto poi) { /* giữ nguyên như cũ */ }
    async Task Delete(int id) { /* giữ nguyên như cũ */ }
}