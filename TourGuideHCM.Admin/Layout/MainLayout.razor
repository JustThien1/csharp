@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <!-- Sidebar -->
    <MudDrawer Open="true" Elevation="1" Variant="DrawerVariant.Mini">
        <NavMenu />
    </MudDrawer>

    <!-- Main content -->
    <MudMainContent>

        <!-- Top bar -->
        <MudAppBar Elevation="1" Color="Color.Primary">
            <MudText Typo="Typo.h6">TourGuide Admin</MudText>
        </MudAppBar>

        <!-- Page content -->
        <MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
            @Body
        </MudContainer>

    </MudMainContent>

</MudLayout>