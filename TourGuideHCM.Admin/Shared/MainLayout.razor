@inherits LayoutComponentBase
@using MudBlazor
@using Microsoft.AspNetCore.Components.Routing   

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <!-- DARK SIDEBAR giống hình bạn muốn -->
    <MudDrawer Open="true"
               Elevation="2"
               Variant="DrawerVariant.Persistent"
               Width="280px"
               Style="background: linear-gradient(180deg, #0f172a 0%, #1e2937 100%); color: white;">

        <div class="pa-4 d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.h5" Class="ml-3 font-weight-bold">TourGuide HCM</MudText>
        </div>
        <MudText Class="px-6 mud-text-secondary mb-4">Quản trị viên</MudText>

        <MudDivider Class="my-2" />

        <NavMenu />
    </MudDrawer>

    <!-- MAIN CONTENT -->
    <MudMainContent>
        <!-- TOP BAR -->
        <MudAppBar Elevation="1" Color="Color.Primary">
            <MudText Typo="Typo.h6" Class="ml-4">Hệ thống Quản trị TourGuide HCM</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined" Color="Color.Inherit"
                       StartIcon="@Icons.Material.Filled.Refresh" OnClick="RefreshPage">
                🔄 Làm mới
            </MudButton>
        </MudAppBar>

        <!-- Nội dung trang -->
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6 mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    [Inject] NavigationManager NavigationManager { get; set; } = default!;

    private void RefreshPage()
    {
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }
}