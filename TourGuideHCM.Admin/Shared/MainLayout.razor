@inherits LayoutComponentBase
@using MudBlazor
@using Microsoft.AspNetCore.Components.Routing

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <!-- SIDEBAR -->
    <MudDrawer Open="true"
               Elevation="0"
               Variant="DrawerVariant.Persistent"
               Width="272px"
               Style="background: #0f1621; border-right: 1px solid #1e2d40; color: white;">

        <!-- Logo -->
        <div style="padding: 24px 20px 16px 20px; display: flex; align-items: center; gap: 12px; border-bottom: 1px solid #1e2d40;">
            <div style="width: 38px; height: 38px; background: linear-gradient(135deg, #3b82f6, #6366f1); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Small" Style="color: white;" />
            </div>
            <div>
                <MudText Typo="Typo.subtitle1" Style="color: #f1f5f9; font-weight: 700; line-height: 1.2;">TourGuide HCM</MudText>
                <MudText Typo="Typo.caption" Style="color: #64748b;">Quản trị viên</MudText>
            </div>
        </div>

        <NavMenu />
    </MudDrawer>

    <!-- MAIN CONTENT -->
    <MudMainContent Style="background: #f8fafc;">
        <!-- TOP BAR -->
        <MudAppBar Elevation="0"
                   Style="background: #ffffff; border-bottom: 1px solid #e2e8f0; color: #1e293b;">
            <MudText Typo="Typo.subtitle1" Style="color: #334155; font-weight: 600; margin-left: 8px;">
                Hệ thống Quản trị TourGuide HCM
            </MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined"
                       Style="border-color: #cbd5e1; color: #475569; border-radius: 8px; text-transform: none; font-weight: 500;"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="RefreshPage">
                Làm mới
            </MudButton>
        </MudAppBar>

        <!-- Page content -->
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6 mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    [Inject] NavigationManager NavigationManager { get; set; } = default!;

    private MudTheme _theme = new MudTheme
    {
        Palette = new PaletteLight
        {
            Primary = "#3b82f6",
            Secondary = "#6366f1",
            Background = "#f8fafc",
            Surface = "#ffffff",
            AppbarBackground = "#ffffff",
            AppbarText = "#1e293b",
            DrawerBackground = "#0f1621",
            DrawerText = "#cbd5e1",
            DrawerIcon = "#64748b",
        }
    };

    private void RefreshPage()
    {
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }
}
