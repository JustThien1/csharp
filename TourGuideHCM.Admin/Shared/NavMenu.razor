@using MudBlazor

<MudNavMenu Dense="true" Style="padding: 12px 8px;">

    <MudText Typo="Typo.overline"
             Style="font-size: 10px; letter-spacing: 1.5px; color: #475569; padding: 16px 14px 6px 14px; display: block; font-weight: 600;">
        QUẢN LÝ NỘI DUNG
    </MudText>

    <MudNavLink Href="/poi"
                Icon="@Icons.Material.Filled.Place"
                Style="border-radius: 8px; margin: 2px 0; color: #94a3b8;"
                ActiveClass="nav-active">
        Địa điểm (POI)
    </MudNavLink>

    <MudNavLink Href="/audio"
                Icon="@Icons.Material.Filled.MusicNote"
                Style="border-radius: 8px; margin: 2px 0; color: #94a3b8;"
                ActiveClass="nav-active">
        Audio Guide
    </MudNavLink>

    <MudNavLink Href="/tour"
                Icon="@Icons.Material.Filled.Map"
                Style="border-radius: 8px; margin: 2px 0; color: #94a3b8;"
                ActiveClass="nav-active">
        Quản lý Tour
    </MudNavLink>

    <MudNavLink Href="/qrcode"
                Icon="@Icons.Material.Filled.QrCode2"
                Style="border-radius: 8px; margin: 2px 0; color: #94a3b8;"
                ActiveClass="nav-active">
        QR Code
    </MudNavLink>

    <div style="border-top: 1px solid #1e2d40; margin: 12px 6px;"></div>

    <MudText Typo="Typo.overline"
             Style="font-size: 10px; letter-spacing: 1.5px; color: #475569; padding: 8px 14px 6px 14px; display: block; font-weight: 600;">
        PHÂN TÍCH DỮ LIỆU
    </MudText>

    <MudNavLink Href="/route-tracking"
                Icon="@Icons.Material.Filled.Route"
                Style="border-radius: 8px; margin: 2px 0; color: #94a3b8;"
                ActiveClass="nav-active">
        Tuyến di chuyển
    </MudNavLink>

    <MudNavLink Href="/history"
                Icon="@Icons.Material.Filled.History"
                Style="border-radius: 8px; margin: 2px 0; color: #94a3b8;"
                ActiveClass="nav-active">
        Lịch sử nghe
    </MudNavLink>

    <MudNavLink Href="/heatmap"
                Icon="@Icons.Material.Filled.Whatshot"
                Style="border-radius: 8px; margin: 2px 0; color: #94a3b8;"
                ActiveClass="nav-active">
        Heatmap
    </MudNavLink>

    <div style="border-top: 1px solid #1e2d40; margin: 12px 6px;"></div>

    <MudText Typo="Typo.overline"
             Style="font-size: 10px; letter-spacing: 1.5px; color: #475569; padding: 8px 14px 6px 14px; display: block; font-weight: 600;">
        HỆ THỐNG
    </MudText>

    <MudNavLink Href="/users"
                Icon="@Icons.Material.Filled.People"
                Style="border-radius: 8px; margin: 2px 0; color: #94a3b8;"
                ActiveClass="nav-active">
        Người dùng
    </MudNavLink>

</MudNavMenu>

<style>
    .nav-active {
        background-color: #1e3a5f !important;
        color: #60a5fa !important;
    }

        .nav-active .mud-nav-link-icon {
            color: #3b82f6 !important;
        }

    .mud-nav-link:hover {
        background-color: #1a2535 !important;
        color: #e2e8f0 !important;
    }
</style>
