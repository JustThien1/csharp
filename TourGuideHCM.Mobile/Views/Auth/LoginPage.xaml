<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideHCM.Mobile.Views.Auth.LoginPage">

    <VerticalStackLayout Padding="30">

        <Entry x:Name="txtUsername" Placeholder="Username"/>
        <Entry x:Name="txtPassword" Placeholder="Password" IsPassword="True"/>

        <Button Text="Login" Clicked="OnLoginClicked"/>
		<Label Text="Chưa có tài khoản? Đăng ký"
       TextColor="Blue">
			<Label.GestureRecognizers>
				<TapGestureRecognizer Tapped="OnRegisterTapped"/>
			</Label.GestureRecognizers>
		</Label>

    </VerticalStackLayout>
</ContentPage>