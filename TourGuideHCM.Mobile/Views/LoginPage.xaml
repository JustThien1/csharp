<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourGuideHCM.Mobile.Views.LoginPage">

    <VerticalStackLayout Padding="30" Spacing="15">

        <Label Text="LOGIN" FontSize="26" HorizontalOptions="Center"/>

        <Entry x:Name="txtUsername" Placeholder="Username"/>
        <Entry x:Name="txtPassword" Placeholder="Password" IsPassword="True"/>

        <Button Text="Login" Clicked="OnLoginClicked"/>

    </VerticalStackLayout>

</ContentPage>