<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="TourGuideHCM.App.Views.PoiDetailPage"
    Title="Chi tiết">

	<ScrollView>

		<VerticalStackLayout Spacing="15">

			<!-- 📸 Ảnh POI -->
			<Grid HeightRequest="220">
				<Image Source="{Binding ImageUrl}"
                       Aspect="AspectFill"/>

				<!-- overlay mờ -->
				<BoxView BackgroundColor="#80000000"/>

				<!-- tên đè lên ảnh -->
				<Label Text="{Binding Name}"
                       TextColor="White"
                       FontSize="22"
                       FontAttributes="Bold"
                       VerticalOptions="End"
                       Margin="15"/>
			</Grid>

			<!-- 📄 Nội dung -->
			<VerticalStackLayout Padding="15" Spacing="10">

				<Label Text="Mô tả"
                       FontSize="16"
                       FontAttributes="Bold"/>

				<Label Text="{Binding Description}"
                       FontSize="14"
                       LineHeight="1.4"/>

			</VerticalStackLayout>

			<!-- 🔊 Button -->
			<Button Text="🔊 Nghe thuyết minh"
                    Margin="15"
                    HeightRequest="50"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    Clicked="OnSpeakClicked"/>

		</VerticalStackLayout>

	</ScrollView>

</ContentPage>