<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideHCM.App.Views.PoiDetailPage"
             Title="{Binding Name}">

	<ScrollView>
		<VerticalStackLayout Spacing="0">

			<!-- Ảnh hero -->
			<Grid HeightRequest="280">
				<Image Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="280"/>
				<BoxView VerticalOptions="End" HeightRequest="100">
					<BoxView.Background>
						<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
							<GradientStop Color="Transparent" Offset="0"/>
							<GradientStop Color="#CC000000" Offset="1"/>
						</LinearGradientBrush>
					</BoxView.Background>
				</BoxView>
				<Label Text="{Binding Name}" FontSize="22" FontAttributes="Bold"
                       TextColor="White" VerticalOptions="End" Margin="16,0,16,16"/>
			</Grid>

			<VerticalStackLayout Padding="16" Spacing="16">

				<!-- Category + khoảng cách -->
				<HorizontalStackLayout Spacing="12">
					<Frame CornerRadius="12" Padding="10,4" BackgroundColor="#1976D2"
                           HasShadow="False" BorderColor="Transparent">
						<Label Text="{Binding CategoryName}" TextColor="White" FontSize="13"/>
					</Frame>
					<Label Text="{Binding DistanceDisplay}"
                           FontSize="13" TextColor="#666" VerticalOptions="Center"/>
					<Label Text="{Binding TicketDisplay}"
                           FontSize="13" TextColor="#1976D2" VerticalOptions="Center"/>
				</HorizontalStackLayout>

				<!-- Nút nghe -->
				<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
					<Button Grid.Column="0" x:Name="PlayViBtn"
                            BackgroundColor="#1976D2" TextColor="White"
                            CornerRadius="12" HeightRequest="48"/>
					<Button Grid.Column="1" x:Name="PlayEnBtn"
                            BackgroundColor="#388E3C" TextColor="White"
                            CornerRadius="12" HeightRequest="48"/>
				</Grid>

				<!-- Nút dừng -->
				<Button x:Name="StopBtn"
                        BackgroundColor="#E53935" TextColor="White"
                        CornerRadius="12" HeightRequest="44"
                        IsVisible="False"/>

				<!-- Mô tả -->
				<Label x:Name="IntroLabel"
                       FontSize="16" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"/>

				<Label Text="{Binding Description}"
                       FontSize="14" LineHeight="1.6"
                       TextColor="{AppThemeBinding Light=#444, Dark=#BBB}"/>

				<!-- Thông tin vị trí -->
				<Frame CornerRadius="12" Padding="16"
                       BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#2A2A2A}"
                       BorderColor="Transparent" HasShadow="False">
					<Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
						<Label Grid.Row="0" Grid.ColumnSpan="2"
                               x:Name="LocationInfoLabel"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#333, Dark=#EEE}"/>
						<Label Grid.Row="1" Grid.Column="0" x:Name="LatLabel"
                               FontSize="12" TextColor="#888"/>
						<Label Grid.Row="1" Grid.Column="1"
                               Text="{Binding Lat, StringFormat='{0:F6}'}"
                               FontSize="12" TextColor="{AppThemeBinding Light=#333, Dark=#DDD}"/>
						<Label Grid.Row="2" Grid.Column="0" x:Name="LngLabel"
                               FontSize="12" TextColor="#888"/>
						<Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding Lng, StringFormat='{0:F6}'}"
                               FontSize="12" TextColor="{AppThemeBinding Light=#333, Dark=#DDD}"/>
					</Grid>
				</Frame>

			</VerticalStackLayout>
		</VerticalStackLayout>
	</ScrollView>
</ContentPage>
