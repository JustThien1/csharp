<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="TourGuideHCM.App.Views.MapPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="True">

    <ContentPage.Resources>
        <Style x:Key="CardStyle" TargetType="Frame">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="HasShadow" Value="True"/>
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark=#1E1E1E}"/>
            <Setter Property="BorderColor" Value="Transparent"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0">
            <maps:Map x:Name="MainMap"
                      IsShowingUser="True" MapType="Street"
                      IsScrollEnabled="True" IsZoomEnabled="True"
                      MapClicked="OnMapClicked"/>

            <!-- Loading overlay -->
            <Grid IsVisible="{Binding IsLoading}"
                  BackgroundColor="#80000000"
                  HorizontalOptions="Fill" VerticalOptions="Fill">
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                    <ActivityIndicator IsRunning="True" Color="White" WidthRequest="40" HeightRequest="40"/>
                    <Label Text="{Binding StatusMessage}" TextColor="White" FontSize="14" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Thanh trạng thái -->
            <Frame Margin="12,12,12,0" VerticalOptions="Start" HorizontalOptions="Fill"
                   CornerRadius="12" Padding="12,8"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                   HasShadow="True" BorderColor="Transparent">
                <Label Text="{Binding StatusMessage}" FontSize="13"
                       TextColor="{AppThemeBinding Light=#555, Dark=#CCC}"
                       VerticalOptions="Center" MaxLines="1"/>
            </Frame>

            <!-- Góc dưới trái: nút ngôn ngữ UI + slider bán kính -->
            <VerticalStackLayout Margin="12" VerticalOptions="End" HorizontalOptions="Start" Spacing="8">

                <!-- Nút đổi ngôn ngữ UI -->
                <Frame CornerRadius="24" Padding="0" HasShadow="True" BorderColor="Transparent"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                       WidthRequest="56" HeightRequest="56">
                    <Button x:Name="LangBtn"
                            Command="{Binding ToggleAppLanguageCommand}"
                            FontSize="11" FontAttributes="Bold"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light=#333, Dark=#EEE}"/>
                </Frame>

                <!-- Slider bán kính -->
                <Frame CornerRadius="12" Padding="10,8" HasShadow="True" BorderColor="Transparent"
                       BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                       WidthRequest="160">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="RadiusLabel"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#333, Dark=#EEE}"
                               HorizontalOptions="Center"/>
                        <Slider Minimum="50" Maximum="500"
                                Value="{Binding ActivationRadius}"
                                ThumbColor="#1976D2"
                                MinimumTrackColor="#1976D2"
                                MaximumTrackColor="#CCCCCC"/>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>

            <!-- Nút vị trí của tôi -->
            <Frame Margin="12,0,12,72" VerticalOptions="End" HorizontalOptions="End"
                   CornerRadius="28" Padding="0" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                   WidthRequest="56" HeightRequest="56">
                <Button x:Name="MyLocationBtn"
                        Text="📍" FontSize="22"
                        BackgroundColor="Transparent"
                        Clicked="OnMyLocationClicked"/>
            </Frame>

            <!-- Nút dừng narration -->
            <Frame IsVisible="{Binding IsNarrating}"
                   Margin="12" VerticalOptions="End" HorizontalOptions="End"
                   CornerRadius="28" Padding="0" HasShadow="True" BorderColor="Transparent"
                   BackgroundColor="#E53935" WidthRequest="56" HeightRequest="56">
                <Button x:Name="StopBtn"
                        Command="{Binding StopNarrationCommand}"
                        FontSize="20" TextColor="White" BackgroundColor="Transparent"/>
            </Frame>
        </Grid>

        <!-- Panel POI chi tiết -->
        <Grid Grid.Row="0" VerticalOptions="End" IsVisible="{Binding IsPoiDetailVisible}">
            <Frame Style="{StaticResource CardStyle}" CornerRadius="20">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto,Auto" RowSpacing="8">
                    <Image Grid.Row="0" Grid.ColumnSpan="3"
                           Source="{Binding SelectedPoi.ImageUrl}"
                           HeightRequest="160" Aspect="AspectFill"/>
                    <Label Grid.Row="1" Grid.Column="0"
                           Text="{Binding SelectedPoi.Name}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"/>
                    <Button Grid.Row="1" Grid.Column="1"
                            Command="{Binding ToggleFavoriteCommand}"
                            CommandParameter="{Binding SelectedPoi}"
                            Text="{Binding SelectedPoi.FavoriteIcon}"
                            FontSize="20" BackgroundColor="Transparent"
                            WidthRequest="40" HeightRequest="40"/>
                    <Button Grid.Row="1" Grid.Column="2"
                            Command="{Binding ClosePoiDetailCommand}"
                            Text="✕" FontSize="16" TextColor="#999"
                            BackgroundColor="Transparent"
                            WidthRequest="36" HeightRequest="36"/>
                    <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="3" Spacing="8">
                        <Label Text="{Binding SelectedPoi.CategoryName}"
                               FontSize="12" TextColor="White"
                               BackgroundColor="#4CAF50" Padding="8,4"/>
                        <Label Text="{Binding SelectedPoi.DistanceDisplay}"
                               FontSize="12" TextColor="#666" VerticalOptions="Center"/>
                        <Label Text="{Binding SelectedPoi.TicketDisplay}"
                               FontSize="12" TextColor="#1976D2" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Grid.Row="3" Grid.ColumnSpan="3"
                           Text="{Binding SelectedPoi.Description}"
                           FontSize="14" LineBreakMode="TailTruncation" MaxLines="3"
                           TextColor="{AppThemeBinding Light=#444, Dark=#BBB}"/>
                    <Button Grid.Row="4" Grid.ColumnSpan="3"
                            x:Name="ListenDetailBtn"
                            Command="{Binding PlayNarrationCommand}"
                            CommandParameter="{Binding SelectedPoi}"
                            FontSize="14" BackgroundColor="#1976D2"
                            TextColor="White" CornerRadius="12"
                            HorizontalOptions="Fill"/>
                </Grid>
            </Frame>
        </Grid>

        <!-- Bottom bar -->
        <Frame Grid.Row="1" Style="{StaticResource CardStyle}"
               Margin="12,0,12,12"
               BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <BoxView Grid.Column="0" WidthRequest="6" CornerRadius="3"
                         BackgroundColor="#FF6F00" VerticalOptions="Fill" Margin="0,0,10,0"/>
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label x:Name="NearestLabel" FontSize="11" TextColor="#999"/>
                    <Label Text="{Binding NearestPoi.Name}"
                           FontSize="15" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"/>
                    <Label Text="{Binding NearestPoi.DistanceDisplay}"
                           FontSize="12" TextColor="#1976D2"/>
                </VerticalStackLayout>
                <Button Grid.Column="2"
                        Command="{Binding ToggleFavoriteCommand}"
                        CommandParameter="{Binding NearestPoi}"
                        Text="{Binding NearestPoi.FavoriteIcon}"
                        FontSize="22" BackgroundColor="Transparent"
                        WidthRequest="44" HeightRequest="44" Padding="0"
                        VerticalOptions="Center"/>
                <Button Grid.Column="3"
                        x:Name="ListenBtn"
                        Command="{Binding PlayNarrationCommand}"
                        CommandParameter="{Binding NearestPoi}"
                        FontSize="14" BackgroundColor="#1976D2"
                        TextColor="White" CornerRadius="20" Padding="16,8"
                        VerticalOptions="Center"/>
            </Grid>
        </Frame>

    </Grid>
</ContentPage>
