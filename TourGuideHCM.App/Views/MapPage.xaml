<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideHCM.App.Views.MapPage"
             Title="Bản đồ">

    <Grid>

        <!-- WebView Bản đồ -->
        <WebView x:Name="MyWebView"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill" />

        <!-- Header mỏng + nút 3 gạch -->
        <VerticalStackLayout Spacing="0" VerticalOptions="Start">
            <Border BackgroundColor="#1E1E1E" 
                    Padding="12,10"
                    StrokeShape="RoundRectangle 0,0,0,0">

                <Grid ColumnDefinitions="Auto,*">
                    <!-- Nút 3 gạch -->
                    <Button Text="☰" 
                            FontSize="26"
                            BackgroundColor="Transparent"
                            TextColor="#FFCC00"
                            WidthRequest="50"
                            HeightRequest="50"
                            Clicked="OnHamburgerClicked"
                            VerticalOptions="Center"
                            HorizontalOptions="Start"/>

                    <!-- Tiêu đề -->
                    <Label Text="Sài Gòn Guide" 
                           TextColor="#FFCC00"
                           FontSize="19"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Grid.Column="1"/>
                </Grid>

            </Border>
        </VerticalStackLayout>

        <!-- Nút nổi bên phải -->
        <VerticalStackLayout VerticalOptions="End"
                             HorizontalOptions="End"
                             Margin="20"
                             Spacing="12">

            <Button Text="📍 Vị trí của tôi"
                    BackgroundColor="#6C4CF1"
                    TextColor="White"
                    CornerRadius="25"
                    HeightRequest="48"
                    Clicked="OnGoToLocationClicked"/>

            <Button Text="🔄 Tải lại"
                    BackgroundColor="#6C4CF1"
                    TextColor="White"
                    CornerRadius="25"
                    HeightRequest="48"
                    Clicked="OnReloadClicked"/>

        </VerticalStackLayout>

    </Grid>

</ContentPage>