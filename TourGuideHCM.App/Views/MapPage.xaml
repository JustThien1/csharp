<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="TourGuideHCM.App.Views.MapPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="True">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0">
            <maps:Map x:Name="MainMap"
                      IsShowingUser="True" MapType="Street"
                      IsScrollEnabled="True" IsZoomEnabled="True"
                      MapClicked="OnMapClicked"/>

            <!-- Loading overlay -->
            <Grid IsVisible="{Binding IsLoading}"
                  BackgroundColor="#80FFFFFF"
                  HorizontalOptions="Fill" VerticalOptions="Fill">
                <Border HorizontalOptions="Center" VerticalOptions="Center"
                        StrokeThickness="0" Padding="32,24">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <SolidColorBrush Color="White"/>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#30000000" Offset="0,8" Radius="24" Opacity="0.15"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                        <ActivityIndicator IsRunning="True" Color="#FF7043"
                                           WidthRequest="36" HeightRequest="36"/>
                        <Label Text="{Binding StatusMessage}" TextColor="#1A1A2E"
                               FontSize="14" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Status bar -->
            <Border Margin="12,12,12,0" VerticalOptions="Start" HorizontalOptions="Fill"
                    StrokeThickness="0" Padding="14,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Background>
                    <SolidColorBrush Color="#F8FAFEFF"/>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,4" Radius="12" Opacity="0.1"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="Auto,*">
                    <Ellipse Grid.Column="0" WidthRequest="8" HeightRequest="8"
                             Fill="#00D4AA" VerticalOptions="Center" Margin="0,0,8,0"/>
                    <Label Grid.Column="1" Text="{Binding StatusMessage}" FontSize="13"
                           TextColor="#6B7A8D" VerticalOptions="Center" MaxLines="1"/>
                </Grid>
            </Border>

            <!-- Góc dưới trái: nút ngôn ngữ + slider -->
            <VerticalStackLayout Margin="12" VerticalOptions="End"
                                 HorizontalOptions="Start" Spacing="10">

                <!-- Nút ngôn ngữ -->
                <Border StrokeThickness="0" WidthRequest="52" HeightRequest="52">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <SolidColorBrush Color="White"/>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#30000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                    </Border.Shadow>
                    <Button x:Name="LangBtn"
                            Command="{Binding ToggleAppLanguageCommand}"
                            FontSize="11" FontAttributes="Bold"
                            BackgroundColor="Transparent" TextColor="#FF7043"/>
                </Border>

                <!-- Slider bán kính -->
                <Border StrokeThickness="0" Padding="12,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <SolidColorBrush Color="White"/>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#30000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6" WidthRequest="150">
                        <Label x:Name="RadiusLabel" FontSize="11" FontAttributes="Bold"
                               TextColor="#FF7043" HorizontalOptions="Center"/>
                        <Slider Minimum="50" Maximum="500"
                                Value="{Binding ActivationRadius}"
                                ThumbColor="#FF7043"
                                MinimumTrackColor="#FF7043"
                                MaximumTrackColor="#E8EEF4"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Nút vị trí -->
            <Border Margin="12,0,12,80" VerticalOptions="End" HorizontalOptions="End"
                    StrokeThickness="0" WidthRequest="52" HeightRequest="52">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00D4AA" Offset="0"/>
                        <GradientStop Color="#00B894" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#6000D4AA" Offset="0,4" Radius="12" Opacity="0.4"/>
                </Border.Shadow>
                <Button x:Name="MyLocationBtn" Text="📍" FontSize="20"
                        BackgroundColor="Transparent" Clicked="OnMyLocationClicked"/>
            </Border>

            <!-- Nút dừng narration -->
            <Border IsVisible="{Binding IsNarrating}"
                    Margin="12" VerticalOptions="End" HorizontalOptions="End"
                    StrokeThickness="0" WidthRequest="52" HeightRequest="52">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF5252" Offset="0"/>
                        <GradientStop Color="#FF1744" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#60FF5252" Offset="0,4" Radius="12" Opacity="0.4"/>
                </Border.Shadow>
                <Button x:Name="StopBtn" Command="{Binding StopNarrationCommand}"
                        Text="⏹" FontSize="18" TextColor="White" BackgroundColor="Transparent"/>
            </Border>

            <!-- NÚT QUÉT QR DUY NHẤT (mới) -->
            <Border Margin="12,0,12,140" 
                    VerticalOptions="End" 
                    HorizontalOptions="Start"
                    StrokeThickness="0" 
                    WidthRequest="60" 
                    HeightRequest="60">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF7043" Offset="0"/>
                        <GradientStop Color="#FFA040" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#60FF7043" Offset="0,4" Radius="12" Opacity="0.4"/>
                </Border.Shadow>
                <Button x:Name="ScanQrBtn"
                        Text="📷"
                        FontSize="26"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        Clicked="OnScanQrClicked"
                        Padding="0"/>
            </Border>

            <!-- ====================== AUDIO QUEUE OVERLAY ====================== -->
            <!-- Thu gọn thành icon 🎧 nhỏ; bấm vào để mở rộng ra card chi tiết -->

            <!-- STATE 1: Collapsed — chỉ icon nhỏ ở góc trên phải -->
            <Border VerticalOptions="Start" HorizontalOptions="End"
                    Margin="0,80,12,0"
                    WidthRequest="56" HeightRequest="56"
                    StrokeThickness="0">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding HasQueue}" Value="False">
                        <Setter Property="IsVisible" Value="False"/>
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsQueueExpanded}" Value="True">
                        <Setter Property="IsVisible" Value="False"/>
                    </DataTrigger>
                </Border.Triggers>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28"/>
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF7043" Offset="0"/>
                        <GradientStop Color="#FFA040" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#60FF7043" Offset="0,4" Radius="12" Opacity="0.4"/>
                </Border.Shadow>
                <Button Command="{Binding ToggleQueueExpandedCommand}"
                        Text="🎧" FontSize="22"
                        BackgroundColor="Transparent" TextColor="White"
                        Padding="0"/>
            </Border>

            <!-- STATE 2: Expanded — card đầy đủ -->
            <Border VerticalOptions="Start" HorizontalOptions="End"
                    Margin="12,80,12,0"
                    MaximumWidthRequest="340"
                    StrokeThickness="0" Padding="0"
                    IsVisible="{Binding IsQueueExpanded}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <Border.Background>
                    <SolidColorBrush Color="#FAFFFFFF"/>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#40000000" Offset="0,6" Radius="16" Opacity="0.25"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="0" Padding="14,12">

                    <!-- Header: tiêu đề + nút collapse -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                        <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                            <Label Text="🎧" FontSize="16"/>
                            <Label Text="Đang phát" FontSize="13" FontAttributes="Bold"
                                   TextColor="#1A1A2E" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Button Grid.Column="1"
                                Command="{Binding ToggleQueueExpandedCommand}"
                                Text="▼" FontSize="14"
                                BackgroundColor="Transparent" TextColor="#6B7A8D"
                                WidthRequest="30" HeightRequest="30" Padding="0"/>
                    </Grid>

                    <!-- Current playing POI -->
                    <Border StrokeThickness="0" Padding="10">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding CurrentPlayingPoi}" Value="{x:Null}">
                                <Setter Property="IsVisible" Value="False"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFF0EB" Offset="0"/>
                                <GradientStop Color="#FFF8F4" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                            <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding CurrentPlayingPoi.Poi.Name}"
                                       FontSize="14" FontAttributes="Bold" TextColor="#1A1A2E"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                                <Label FontSize="11" TextColor="#FF7043"
                                       Text="{Binding CurrentPlayingPoi.Distance, StringFormat='cách {0:F0}m'}"/>
                            </VerticalStackLayout>

                            <!-- Skip -->
                            <Button Grid.Column="1"
                                    Command="{Binding SkipCurrentCommand}"
                                    Text="⏭" FontSize="16"
                                    BackgroundColor="Transparent" TextColor="#FF7043"
                                    WidthRequest="34" HeightRequest="34" Padding="0"/>

                            <!-- Stop -->
                            <Button Grid.Column="2"
                                    Command="{Binding StopQueueCommand}"
                                    Text="⏹" FontSize="16"
                                    BackgroundColor="Transparent" TextColor="#E53935"
                                    WidthRequest="34" HeightRequest="34" Padding="0"/>
                        </Grid>
                    </Border>

                    <!-- Separator (chỉ hiện khi có POI đang chờ) -->
                    <BoxView HeightRequest="1" Color="#EEF0F6" Margin="0,10,0,8">
                        <BoxView.Triggers>
                            <DataTrigger TargetType="BoxView" Binding="{Binding AudioQueue.Count}" Value="0">
                                <Setter Property="IsVisible" Value="False"/>
                            </DataTrigger>
                        </BoxView.Triggers>
                    </BoxView>

                    <!-- Up next header -->
                    <Label FontSize="12" FontAttributes="Bold" TextColor="#6B7A8D"
                           Margin="0,0,0,6"
                           Text="{Binding AudioQueue.Count, StringFormat='📋 Sắp tới ({0})'}">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding AudioQueue.Count}" Value="0">
                                <Setter Property="IsVisible" Value="False"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                    <!-- Queue list -->
                    <CollectionView ItemsSource="{Binding AudioQueue}"
                                    MaximumHeightRequest="180"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="4,6" ColumnSpacing="8">
                                    <Ellipse Grid.Column="0"
                                             WidthRequest="6" HeightRequest="6"
                                             Fill="#FF7043" VerticalOptions="Center"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding Poi.Name}"
                                           FontSize="13" TextColor="#1A1A2E"
                                           VerticalOptions="Center"
                                           MaxLines="1" LineBreakMode="TailTruncation"/>
                                    <Label Grid.Column="2"
                                           FontSize="11" TextColor="#6B7A8D"
                                           VerticalOptions="Center"
                                           Text="{Binding Distance, StringFormat='{0:F0}m'}"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- POI Detail panel -->
        <Grid Grid.Row="0" VerticalOptions="End" IsVisible="{Binding IsPoiDetailVisible}"
              Margin="12,0,12,8">
            <Border StrokeThickness="0" Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>
                <Border.Background>
                    <SolidColorBrush Color="White"/>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#40000000" Offset="0,8" Radius="24" Opacity="0.2"/>
                </Border.Shadow>

                <Grid RowDefinitions="180,Auto,Auto,Auto,Auto">
                    <Border Grid.Row="0" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24,24,0,0"/>
                        </Border.StrokeShape>
                        <Image Source="{Binding SelectedPoi.ImageUrl}"
                               HeightRequest="180" Aspect="AspectFill"/>
                    </Border>
                    <BoxView Grid.Row="0" VerticalOptions="End" HeightRequest="80">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#CC000000" Offset="1"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <Grid Grid.Row="0" VerticalOptions="End" Padding="14,10"
                          ColumnDefinitions="*,Auto,Auto">
                        <Label Grid.Column="0" Text="{Binding SelectedPoi.Name}"
                               FontSize="17" FontAttributes="Bold" TextColor="White"/>
                        <Button Grid.Column="1"
                                Command="{Binding ToggleFavoriteCommand}"
                                CommandParameter="{Binding SelectedPoi}"
                                Text="{Binding SelectedPoi.FavoriteIcon}"
                                FontSize="20" BackgroundColor="Transparent"
                                WidthRequest="38" HeightRequest="38"/>
                        <Button Grid.Column="2" Command="{Binding ClosePoiDetailCommand}"
                                Text="✕" FontSize="15" TextColor="#CCDDEE"
                                BackgroundColor="Transparent"
                                WidthRequest="34" HeightRequest="34"/>
                    </Grid>

                    <HorizontalStackLayout Grid.Row="1" Spacing="8" Padding="14,10">
                        <Border StrokeThickness="0" Padding="10,5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00D4AA" Offset="0"/>
                                    <GradientStop Color="#00B894" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Text="{Binding SelectedPoi.CategoryName}"
                                   FontSize="12" TextColor="White" FontAttributes="Bold"/>
                        </Border>
                        <Label Text="{Binding SelectedPoi.DistanceDisplay}"
                               FontSize="12" TextColor="#9AA5B4" VerticalOptions="Center"/>
                        <Label Text="{Binding SelectedPoi.TicketDisplay}"
                               FontSize="12" TextColor="#FF7043" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Label Grid.Row="2" Padding="14,0"
                           Text="{Binding SelectedPoi.Description}"
                           FontSize="13" LineBreakMode="TailTruncation" MaxLines="2"
                           TextColor="#6B7A8D"/>

                    <Border Grid.Row="3" Margin="14,10" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF7043" Offset="0"/>
                                <GradientStop Color="#FFA040" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="#60FF7043" Offset="0,4" Radius="10" Opacity="0.35"/>
                        </Border.Shadow>
                        <Button x:Name="ListenDetailBtn"
                                Command="{Binding PlayNarrationCommand}"
                                CommandParameter="{Binding SelectedPoi}"
                                FontSize="14" BackgroundColor="Transparent"
                                TextColor="White" HeightRequest="48" HorizontalOptions="Fill"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom bar -->
        <Border Grid.Row="1" Margin="12,0,12,12" Padding="14,12"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Border.Background>
                <SolidColorBrush Color="White"/>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#30000000" Offset="0,8" Radius="24" Opacity="0.12"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <Border Grid.Column="0" WidthRequest="4" VerticalOptions="Fill"
                        Margin="0,2,12,2" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="2"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF7043" Offset="0"/>
                            <GradientStop Color="#FFA040" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label x:Name="NearestLabel" FontSize="10" TextColor="#9AA5B4"
                           FontAttributes="Bold"/>
                    <Label Text="{Binding NearestPoi.Name}"
                           FontSize="15" FontAttributes="Bold" TextColor="#1A1A2E"/>
                    <Label Text="{Binding NearestPoi.DistanceDisplay}"
                           FontSize="12" TextColor="#FF7043"/>
                </VerticalStackLayout>

                <Button Grid.Column="2"
                        Command="{Binding ToggleFavoriteCommand}"
                        CommandParameter="{Binding NearestPoi}"
                        Text="{Binding NearestPoi.FavoriteIcon}"
                        FontSize="22" BackgroundColor="Transparent"
                        WidthRequest="42" HeightRequest="42" Padding="0"
                        VerticalOptions="Center"/>

                <Border Grid.Column="3" StrokeThickness="0" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF7043" Offset="0"/>
                            <GradientStop Color="#FFA040" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#60FF7043" Offset="0,3" Radius="8" Opacity="0.3"/>
                    </Border.Shadow>
                    <Button x:Name="ListenBtn"
                            Command="{Binding PlayNarrationCommand}"
                            CommandParameter="{Binding NearestPoi}"
                            FontSize="13" BackgroundColor="Transparent"
                            TextColor="White" Padding="16,10"/>
                </Border>
            </Grid>
        </Border>

    </Grid>
</ContentPage>