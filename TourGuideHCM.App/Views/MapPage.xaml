<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="TourGuideHCM.App.Views.MapPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="True">

    <Grid RowDefinitions="*,Auto">

        <Grid Grid.Row="0">
            <maps:Map x:Name="MainMap"
                      IsShowingUser="True" MapType="Street"
                      IsScrollEnabled="True" IsZoomEnabled="True"
                      MapClicked="OnMapClicked"/>

            <!-- Loading overlay -->
            <Grid IsVisible="{Binding IsLoading}"
                  BackgroundColor="#80FFFFFF"
                  HorizontalOptions="Fill" VerticalOptions="Fill">
                <Border HorizontalOptions="Center" VerticalOptions="Center"
                        StrokeThickness="0" Padding="32,24">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <SolidColorBrush Color="White"/>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#30000000" Offset="0,8" Radius="24" Opacity="0.15"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                        <ActivityIndicator IsRunning="True" Color="#FF7043"
                                           WidthRequest="36" HeightRequest="36"/>
                        <Label Text="{Binding StatusMessage}" TextColor="#1A1A2E"
                               FontSize="14" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Status bar -->
            <Border Margin="12,12,12,0" VerticalOptions="Start" HorizontalOptions="Fill"
                    StrokeThickness="0" Padding="14,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Background>
                    <SolidColorBrush Color="#F8FAFEFF"/>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#20000000" Offset="0,4" Radius="12" Opacity="0.1"/>
                </Border.Shadow>
                <Grid ColumnDefinitions="Auto,*">
                    <Ellipse Grid.Column="0" WidthRequest="8" HeightRequest="8"
                             Fill="#00D4AA" VerticalOptions="Center" Margin="0,0,8,0"/>
                    <Label Grid.Column="1" Text="{Binding StatusMessage}" FontSize="13"
                           TextColor="#6B7A8D" VerticalOptions="Center" MaxLines="1"/>
                </Grid>
            </Border>

            <!-- Góc dưới trái: nút ngôn ngữ + slider -->
            <VerticalStackLayout Margin="12" VerticalOptions="End"
                                 HorizontalOptions="Start" Spacing="10">

                <!-- Nút ngôn ngữ -->
                <Border StrokeThickness="0" WidthRequest="52" HeightRequest="52">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <SolidColorBrush Color="White"/>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#30000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                    </Border.Shadow>
                    <Button x:Name="LangBtn"
                            Command="{Binding ToggleAppLanguageCommand}"
                            FontSize="11" FontAttributes="Bold"
                            BackgroundColor="Transparent" TextColor="#FF7043"/>
                </Border>

                <!-- Slider bán kính -->
                <Border StrokeThickness="0" Padding="12,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <SolidColorBrush Color="White"/>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#30000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6" WidthRequest="150">
                        <Label x:Name="RadiusLabel" FontSize="11" FontAttributes="Bold"
                               TextColor="#FF7043" HorizontalOptions="Center"/>
                        <Slider Minimum="50" Maximum="500"
                                Value="{Binding ActivationRadius}"
                                ThumbColor="#FF7043"
                                MinimumTrackColor="#FF7043"
                                MaximumTrackColor="#E8EEF4"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Nút vị trí -->
            <Border Margin="12,0,12,80" VerticalOptions="End" HorizontalOptions="End"
                    StrokeThickness="0" WidthRequest="52" HeightRequest="52">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00D4AA" Offset="0"/>
                        <GradientStop Color="#00B894" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#6000D4AA" Offset="0,4" Radius="12" Opacity="0.4"/>
                </Border.Shadow>
                <Button x:Name="MyLocationBtn" Text="📍" FontSize="20"
                        BackgroundColor="Transparent" Clicked="OnMyLocationClicked"/>
            </Border>

            <!-- Nút dừng narration -->
            <Border IsVisible="{Binding IsNarrating}"
                    Margin="12" VerticalOptions="End" HorizontalOptions="End"
                    StrokeThickness="0" WidthRequest="52" HeightRequest="52">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF5252" Offset="0"/>
                        <GradientStop Color="#FF1744" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#60FF5252" Offset="0,4" Radius="12" Opacity="0.4"/>
                </Border.Shadow>
                <Button x:Name="StopBtn" Command="{Binding StopNarrationCommand}"
                        Text="⏹" FontSize="18" TextColor="White" BackgroundColor="Transparent"/>
            </Border>
        </Grid>

        <!-- POI Detail panel -->
        <Grid Grid.Row="0" VerticalOptions="End" IsVisible="{Binding IsPoiDetailVisible}"
              Margin="12,0,12,8">
            <Border StrokeThickness="0" Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>
                <Border.Background>
                    <SolidColorBrush Color="White"/>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#40000000" Offset="0,8" Radius="24" Opacity="0.2"/>
                </Border.Shadow>

                <Grid RowDefinitions="180,Auto,Auto,Auto,Auto">
                    <!-- Ảnh -->
                    <Border Grid.Row="0" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24,24,0,0"/>
                        </Border.StrokeShape>
                        <Image Source="{Binding SelectedPoi.ImageUrl}"
                               HeightRequest="180" Aspect="AspectFill"/>
                    </Border>
                    <BoxView Grid.Row="0" VerticalOptions="End" HeightRequest="80">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#CC000000" Offset="1"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Tên + actions -->
                    <Grid Grid.Row="0" VerticalOptions="End" Padding="14,10"
                          ColumnDefinitions="*,Auto,Auto">
                        <Label Grid.Column="0" Text="{Binding SelectedPoi.Name}"
                               FontSize="17" FontAttributes="Bold" TextColor="White"/>
                        <Button Grid.Column="1"
                                Command="{Binding ToggleFavoriteCommand}"
                                CommandParameter="{Binding SelectedPoi}"
                                Text="{Binding SelectedPoi.FavoriteIcon}"
                                FontSize="20" BackgroundColor="Transparent"
                                WidthRequest="38" HeightRequest="38"/>
                        <Button Grid.Column="2" Command="{Binding ClosePoiDetailCommand}"
                                Text="✕" FontSize="15" TextColor="#CCDDEE"
                                BackgroundColor="Transparent"
                                WidthRequest="34" HeightRequest="34"/>
                    </Grid>

                    <!-- Tags -->
                    <HorizontalStackLayout Grid.Row="1" Spacing="8" Padding="14,10">
                        <Border StrokeThickness="0" Padding="10,5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00D4AA" Offset="0"/>
                                    <GradientStop Color="#00B894" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Label Text="{Binding SelectedPoi.CategoryName}"
                                   FontSize="12" TextColor="White" FontAttributes="Bold"/>
                        </Border>
                        <Label Text="{Binding SelectedPoi.DistanceDisplay}"
                               FontSize="12" TextColor="#9AA5B4" VerticalOptions="Center"/>
                        <Label Text="{Binding SelectedPoi.TicketDisplay}"
                               FontSize="12" TextColor="#FF7043" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Mô tả -->
                    <Label Grid.Row="2" Padding="14,0"
                           Text="{Binding SelectedPoi.Description}"
                           FontSize="13" LineBreakMode="TailTruncation" MaxLines="2"
                           TextColor="#6B7A8D"/>

                    <!-- Nút nghe -->
                    <Border Grid.Row="3" Margin="14,10" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF7043" Offset="0"/>
                                <GradientStop Color="#FFA040" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="#60FF7043" Offset="0,4" Radius="10" Opacity="0.35"/>
                        </Border.Shadow>
                        <Button x:Name="ListenDetailBtn"
                                Command="{Binding PlayNarrationCommand}"
                                CommandParameter="{Binding SelectedPoi}"
                                FontSize="14" BackgroundColor="Transparent"
                                TextColor="White" HeightRequest="48" HorizontalOptions="Fill"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom bar -->
        <Border Grid.Row="1" Margin="12,0,12,12" Padding="14,12"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Border.Background>
                <SolidColorBrush Color="White"/>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#30000000" Offset="0,8" Radius="24" Opacity="0.12"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <!-- Accent bar -->
                <Border Grid.Column="0" WidthRequest="4" VerticalOptions="Fill"
                        Margin="0,2,12,2" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="2"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF7043" Offset="0"/>
                            <GradientStop Color="#FFA040" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label x:Name="NearestLabel" FontSize="10" TextColor="#9AA5B4"
                           FontAttributes="Bold"/>
                    <Label Text="{Binding NearestPoi.Name}"
                           FontSize="15" FontAttributes="Bold" TextColor="#1A1A2E"/>
                    <Label Text="{Binding NearestPoi.DistanceDisplay}"
                           FontSize="12" TextColor="#FF7043"/>
                </VerticalStackLayout>

                <Button Grid.Column="2"
                        Command="{Binding ToggleFavoriteCommand}"
                        CommandParameter="{Binding NearestPoi}"
                        Text="{Binding NearestPoi.FavoriteIcon}"
                        FontSize="22" BackgroundColor="Transparent"
                        WidthRequest="42" HeightRequest="42" Padding="0"
                        VerticalOptions="Center"/>

                <Border Grid.Column="3" StrokeThickness="0" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF7043" Offset="0"/>
                            <GradientStop Color="#FFA040" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#60FF7043" Offset="0,3" Radius="8" Opacity="0.3"/>
                    </Border.Shadow>
                    <Button x:Name="ListenBtn"
                            Command="{Binding PlayNarrationCommand}"
                            CommandParameter="{Binding NearestPoi}"
                            FontSize="13" BackgroundColor="Transparent"
                            TextColor="White" Padding="16,10"/>
                </Border>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
