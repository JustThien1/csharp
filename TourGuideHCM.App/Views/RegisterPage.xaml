<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideHCM.App.Views.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

	<ScrollView>
		<VerticalStackLayout Padding="32" Spacing="14" VerticalOptions="Center">

			<Label Text="🗺️" FontSize="56" HorizontalOptions="Center"/>

			<Label x:Name="TitleLabel"
                   Text="Tạo tài khoản"
                   FontSize="24" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"/>

			<!-- Username -->
			<Frame CornerRadius="12" Padding="0" BorderColor="#E0E0E0" HasShadow="False">
				<Entry x:Name="UsernameEntry"
                       Placeholder="Tên đăng nhập *"
                       Margin="12,0" HeightRequest="48"
                       BackgroundColor="Transparent"
                       ReturnType="Next"/>
			</Frame>

			<!-- FullName -->
			<Frame CornerRadius="12" Padding="0" BorderColor="#E0E0E0" HasShadow="False">
				<Entry x:Name="FullNameEntry"
                       Placeholder="Họ và tên"
                       Margin="12,0" HeightRequest="48"
                       BackgroundColor="Transparent"
                       ReturnType="Next"/>
			</Frame>

			<!-- Phone -->
			<Frame CornerRadius="12" Padding="0" BorderColor="#E0E0E0" HasShadow="False">
				<Entry x:Name="PhoneEntry"
                       Placeholder="Số điện thoại"
                       Keyboard="Telephone"
                       Margin="12,0" HeightRequest="48"
                       BackgroundColor="Transparent"
                       ReturnType="Next"/>
			</Frame>

			<!-- Email -->
			<Frame CornerRadius="12" Padding="0" BorderColor="#E0E0E0" HasShadow="False">
				<Entry x:Name="EmailEntry"
                       Placeholder="Email (tùy chọn)"
                       Keyboard="Email"
                       Margin="12,0" HeightRequest="48"
                       BackgroundColor="Transparent"
                       ReturnType="Next"/>
			</Frame>

			<!-- Password -->
			<Frame CornerRadius="12" Padding="0" BorderColor="#E0E0E0" HasShadow="False">
				<Entry x:Name="PasswordEntry"
                       Placeholder="Mật khẩu *"
                       IsPassword="True"
                       Margin="12,0" HeightRequest="48"
                       BackgroundColor="Transparent"
                       ReturnType="Done"/>
			</Frame>

			<!-- Error -->
			<Label x:Name="ErrorLabel"
                   TextColor="#E53935" FontSize="13"
                   IsVisible="False" HorizontalOptions="Center"/>

			<!-- Loading -->
			<ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False" IsVisible="False"
                               Color="#1976D2"/>

			<!-- Register Button -->
			<Button x:Name="RegisterBtn"
                    Text="Tạo tài khoản"
                    BackgroundColor="#1976D2" TextColor="White"
                    CornerRadius="12" HeightRequest="50" FontSize="16"
                    Clicked="OnRegisterClicked"/>

			<!-- Back to Login -->
			<Button x:Name="BackBtn"
                    Text="← Đã có tài khoản? Đăng nhập"
                    BackgroundColor="Transparent"
                    TextColor="#1976D2"
                    FontSize="14"
                    Clicked="OnBackClicked"/>

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>
