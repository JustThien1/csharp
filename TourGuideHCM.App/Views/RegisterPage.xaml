<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideHCM.App.Views.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAFBFF">

	<ScrollView>
		<VerticalStackLayout Padding="28,50,28,40" Spacing="0">

			<!-- Header -->
			<VerticalStackLayout Spacing="6" Margin="0,0,0,32" HorizontalOptions="Center">
				<Border WidthRequest="72" HeightRequest="72"
                        HorizontalOptions="Center" StrokeThickness="0">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="22"/>
					</Border.StrokeShape>
					<Border.Background>
						<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
							<GradientStop Color="#00D4AA" Offset="0"/>
							<GradientStop Color="#00B894" Offset="1"/>
						</LinearGradientBrush>
					</Border.Background>
					<Label Text="✨" FontSize="30"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
				</Border>
				<Label x:Name="TitleLabel" Text="Tạo tài khoản"
                       FontSize="26" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="#1A1A2E" Margin="0,12,0,0"/>
				<Label Text="Tham gia cùng hàng nghìn du khách"
                       FontSize="13" HorizontalOptions="Center" TextColor="#9AA5B4"/>
			</VerticalStackLayout>

			<VerticalStackLayout Spacing="12">

				<!-- Username -->
				<Border StrokeThickness="1.5" Stroke="#EEF0F6">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="18"/>
					</Border.StrokeShape>
					<Border.Background>
						<SolidColorBrush Color="White"/>
					</Border.Background>
					<Border.Shadow>
						<Shadow Brush="#20C0C8D8" Offset="0,4" Radius="12" Opacity="0.12"/>
					</Border.Shadow>
					<Grid ColumnDefinitions="Auto,*" Padding="16,0">
						<Label Grid.Column="0" Text="@" FontSize="18" FontAttributes="Bold"
                               TextColor="#00D4AA" VerticalOptions="Center" Margin="0,0,10,0"/>
						<Entry Grid.Column="1" x:Name="UsernameEntry" Placeholder="Tên đăng nhập *"
                               HeightRequest="54" BackgroundColor="Transparent"
                               TextColor="#1A1A2E" PlaceholderColor="#BCC4D0" ReturnType="Next"/>
					</Grid>
				</Border>

				<!-- FullName -->
				<Border StrokeThickness="1.5" Stroke="#EEF0F6">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="18"/>
					</Border.StrokeShape>
					<Border.Background>
						<SolidColorBrush Color="White"/>
					</Border.Background>
					<Border.Shadow>
						<Shadow Brush="#20C0C8D8" Offset="0,4" Radius="12" Opacity="0.12"/>
					</Border.Shadow>
					<Grid ColumnDefinitions="Auto,*" Padding="16,0">
						<Label Grid.Column="0" Text="👤" FontSize="18"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
						<Entry Grid.Column="1" x:Name="FullNameEntry" Placeholder="Họ và tên"
                               HeightRequest="54" BackgroundColor="Transparent"
                               TextColor="#1A1A2E" PlaceholderColor="#BCC4D0" ReturnType="Next"/>
					</Grid>
				</Border>

				<!-- Phone -->
				<Border StrokeThickness="1.5" Stroke="#EEF0F6">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="18"/>
					</Border.StrokeShape>
					<Border.Background>
						<SolidColorBrush Color="White"/>
					</Border.Background>
					<Border.Shadow>
						<Shadow Brush="#20C0C8D8" Offset="0,4" Radius="12" Opacity="0.12"/>
					</Border.Shadow>
					<Grid ColumnDefinitions="Auto,*" Padding="16,0">
						<Label Grid.Column="0" Text="📱" FontSize="18"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
						<Entry Grid.Column="1" x:Name="PhoneEntry" Placeholder="Số điện thoại"
                               Keyboard="Telephone" HeightRequest="54" BackgroundColor="Transparent"
                               TextColor="#1A1A2E" PlaceholderColor="#BCC4D0" ReturnType="Next"/>
					</Grid>
				</Border>

				<!-- Email -->
				<Border StrokeThickness="1.5" Stroke="#EEF0F6">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="18"/>
					</Border.StrokeShape>
					<Border.Background>
						<SolidColorBrush Color="White"/>
					</Border.Background>
					<Border.Shadow>
						<Shadow Brush="#20C0C8D8" Offset="0,4" Radius="12" Opacity="0.12"/>
					</Border.Shadow>
					<Grid ColumnDefinitions="Auto,*" Padding="16,0">
						<Label Grid.Column="0" Text="✉️" FontSize="18"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
						<Entry Grid.Column="1" x:Name="EmailEntry" Placeholder="Email (tùy chọn)"
                               Keyboard="Email" HeightRequest="54" BackgroundColor="Transparent"
                               TextColor="#1A1A2E" PlaceholderColor="#BCC4D0" ReturnType="Next"/>
					</Grid>
				</Border>

				<!-- Password -->
				<Border StrokeThickness="1.5" Stroke="#EEF0F6">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="18"/>
					</Border.StrokeShape>
					<Border.Background>
						<SolidColorBrush Color="White"/>
					</Border.Background>
					<Border.Shadow>
						<Shadow Brush="#20C0C8D8" Offset="0,4" Radius="12" Opacity="0.12"/>
					</Border.Shadow>
					<Grid ColumnDefinitions="Auto,*" Padding="16,0">
						<Label Grid.Column="0" Text="🔒" FontSize="18"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
						<Entry Grid.Column="1" x:Name="PasswordEntry" Placeholder="Mật khẩu *"
                               IsPassword="True" HeightRequest="54" BackgroundColor="Transparent"
                               TextColor="#1A1A2E" PlaceholderColor="#BCC4D0" ReturnType="Done"/>
					</Grid>
				</Border>

				<Label x:Name="ErrorLabel" TextColor="#FF5252" FontSize="13"
                       IsVisible="False" HorizontalOptions="Center"/>
				<ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False" IsVisible="False" Color="#00D4AA"/>

				<!-- Nút tạo tài khoản -->
				<Border StrokeThickness="0" Margin="0,8,0,0">
					<Border.StrokeShape>
						<RoundRectangle CornerRadius="18"/>
					</Border.StrokeShape>
					<Border.Background>
						<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
							<GradientStop Color="#00D4AA" Offset="0"/>
							<GradientStop Color="#00B894" Offset="1"/>
						</LinearGradientBrush>
					</Border.Background>
					<Border.Shadow>
						<Shadow Brush="#8000D4AA" Offset="0,6" Radius="16" Opacity="0.45"/>
					</Border.Shadow>
					<Button x:Name="RegisterBtn" Text="Tạo tài khoản"
                            BackgroundColor="Transparent" TextColor="White"
                            HeightRequest="56" FontSize="16" FontAttributes="Bold"
                            Clicked="OnRegisterClicked"/>
				</Border>

				<!-- Back to login -->
				<Button x:Name="BackBtn" Text="← Đã có tài khoản? Đăng nhập"
                        BackgroundColor="Transparent" TextColor="#FF7043"
                        FontSize="14" FontAttributes="Bold" Margin="0,4,0,0"
                        Clicked="OnBackClicked"/>

			</VerticalStackLayout>
		</VerticalStackLayout>
	</ScrollView>
</ContentPage>
