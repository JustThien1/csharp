<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TourGuideHCM.App.ViewModels"
             xmlns:models="clr-namespace:TourGuideHCM.App.Models"
             x:Class="TourGuideHCM.App.Views.PoiListPage"
             BackgroundColor="#FAFBFF">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Search header -->
        <VerticalStackLayout Grid.Row="0" Padding="16,14,16,0"
                             BackgroundColor="White">
            <Border StrokeThickness="1.5" Stroke="#EEF0F6">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Background>
                    <SolidColorBrush Color="#FAFBFF"/>
                </Border.Background>
                <Grid ColumnDefinitions="Auto,*" Padding="12,0">
                    <Label Grid.Column="0" Text="🔍" FontSize="16"
                           VerticalOptions="Center" Margin="0,0,6,0"/>
                    <SearchBar Grid.Column="1" x:Name="SearchBar"
                               Text="{Binding SearchText}"
                               BackgroundColor="Transparent"
                               HeightRequest="46"
                               PlaceholderColor="#BCC4D0"/>
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- Filter categories -->
        <Border Grid.Row="1" StrokeThickness="0" Padding="0,10"
                BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,4" Radius="12" Opacity="0.08"/>
            </Border.Shadow>
            <CollectionView ItemsSource="{Binding Categories}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedCategory}"
                            HeightRequest="40">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                </CollectionView.ItemsLayout>
                <CollectionView.Header>
                    <BoxView WidthRequest="8" HeightRequest="1"/>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Border StrokeThickness="1.5" Stroke="#EEF0F6" Padding="14,6">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.Background>
                                <SolidColorBrush Color="#FAFBFF"/>
                            </Border.Background>
                            <Label Text="{Binding .}" FontSize="13"
                                   TextColor="#4A5568" VerticalOptions="Center"/>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <!-- Danh sách POI -->
        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsLoading}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding FilteredPois}"
                            SelectionMode="None"
                            Margin="16,8">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                         Spacing="12" Padding="32">
                        <Label Text="🗺️" FontSize="48" HorizontalOptions="Center"/>
                        <Label x:Name="EmptyLabel" FontSize="16"
                               HorizontalOptions="Center" TextColor="#9AA5B4"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:POI">
                        <Grid Padding="0,6">
                            <Border StrokeThickness="0" Padding="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20"/>
                                </Border.StrokeShape>
                                <Border.Background>
                                    <SolidColorBrush Color="White"/>
                                </Border.Background>
                                <Border.Shadow>
                                    <Shadow Brush="#20000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                                </Border.Shadow>

                                <Grid ColumnDefinitions="130,*">
                                    <!-- Ảnh bên trái -->
                                    <Border Grid.Column="0" StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="20,0,0,20"/>
                                        </Border.StrokeShape>
                                        <Grid>
                                            <BoxView>
                                                <BoxView.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FF7043" Offset="0"/>
                                                        <GradientStop Color="#FFA040" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </BoxView.Background>
                                            </BoxView>
                                            <Image Source="{Binding ImageUrl}"
                                                   Aspect="AspectFill" HeightRequest="115"/>
                                        </Grid>
                                    </Border>

                                    <!-- Nội dung bên phải -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Padding="14,12,12,12"
                                                         Spacing="6">

                                        <!-- Tên -->
                                        <Label Text="{Binding Name}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="#1A1A2E" MaxLines="1"/>

                                        <!-- Category badge -->
                                        <Frame CornerRadius="8" Padding="8,3"
                                               HasShadow="False" BorderColor="Transparent"
                                               HorizontalOptions="Start">
                                            <Frame.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#00D4AA" Offset="0"/>
                                                    <GradientStop Color="#00B894" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Frame.Background>
                                            <Label Text="{Binding CategoryName}"
                                                   FontSize="11" TextColor="White"
                                                   FontAttributes="Bold"/>
                                        </Frame>

                                        <!-- Mô tả ngắn -->
                                        <Label Text="{Binding ShortDescription}"
                                               FontSize="12" TextColor="#9AA5B4"
                                               MaxLines="2" LineBreakMode="TailTruncation"/>

                                        <!-- Nút hành động -->
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                            <!-- Nút Chi tiết -->
                                            <Button Grid.Column="0"
                                                    Text="Chi tiết →"
                                                    FontSize="12" FontAttributes="Bold"
                                                    BackgroundColor="Transparent"
                                                    TextColor="#FF7043"
                                                    HorizontalOptions="Start"
                                                    Padding="0"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectCommand}"
                                                    CommandParameter="{Binding .}"/>

                                            <!-- Nút Nghe -->
                                            <Button Grid.Column="1"
                                                    Text="▶ Nghe"
                                                    FontSize="12" FontAttributes="Bold"
                                                    BackgroundColor="#FF7043"
                                                    TextColor="White"
                                                    CornerRadius="10"
                                                    Padding="12,4"
                                                    HeightRequest="32"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PlayCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>

                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
