<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideHCM.App.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAFBFF">

    <ScrollView>
        <VerticalStackLayout Padding="28,60,28,40" Spacing="0" VerticalOptions="Center">

            <!-- Logo -->
            <VerticalStackLayout Spacing="8" Margin="0,0,0,44" HorizontalOptions="Center">
                <Border WidthRequest="90" HeightRequest="90"
                        HorizontalOptions="Center" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF7043" Offset="0"/>
                            <GradientStop Color="#FFA040" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label Text="🗺️" FontSize="40"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <Label x:Name="TitleLabel"
                       FontSize="28" FontAttributes="Bold"
                       HorizontalOptions="Center" TextColor="#1A1A2E"
                       Margin="0,14,0,0"/>
                <Label Text="Khám phá Thành phố Hồ Chí Minh"
                       FontSize="14" HorizontalOptions="Center" TextColor="#9AA5B4"/>
            </VerticalStackLayout>

            <!-- Nút ngôn ngữ -->
            <Button x:Name="LangBtn" Clicked="OnLangClicked"
                    BackgroundColor="#F0FBF9" TextColor="#00D4AA"
                    FontSize="12" FontAttributes="Bold"
                    CornerRadius="20" HeightRequest="34" Padding="16,0"
                    HorizontalOptions="End" Margin="0,0,0,20"/>

            <VerticalStackLayout Spacing="14">

                <!-- Username -->
                <Border StrokeThickness="1.5" Stroke="#EEF0F6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <SolidColorBrush Color="White"/>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#20C0C8D8" Offset="0,4" Radius="12" Opacity="0.12"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" Padding="16,0">
                        <Label Grid.Column="0" Text="👤" FontSize="18"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Entry Grid.Column="1" x:Name="UsernameEntry"
                               HeightRequest="54" BackgroundColor="Transparent"
                               TextColor="#1A1A2E" PlaceholderColor="#BCC4D0" ReturnType="Next"/>
                    </Grid>
                </Border>

                <!-- Password -->
                <Border StrokeThickness="1.5" Stroke="#EEF0F6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <SolidColorBrush Color="White"/>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#20C0C8D8" Offset="0,4" Radius="12" Opacity="0.12"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" Padding="16,0">
                        <Label Grid.Column="0" Text="🔒" FontSize="18"
                               VerticalOptions="Center" Margin="0,0,10,0"/>
                        <Entry Grid.Column="1" x:Name="PasswordEntry"
                               HeightRequest="54" IsPassword="True"
                               BackgroundColor="Transparent"
                               TextColor="#1A1A2E" PlaceholderColor="#BCC4D0" ReturnType="Done"/>
                    </Grid>
                </Border>

                <Label x:Name="ErrorLabel" TextColor="#FF5252" FontSize="13"
                       IsVisible="False" HorizontalOptions="Center"/>
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False" IsVisible="False" Color="#FF7043"/>

                <!-- Nút đăng nhập -->
                <Border StrokeThickness="0" Margin="0,8,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF7043" Offset="0"/>
                            <GradientStop Color="#FFA040" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#80FF7043" Offset="0,6" Radius="16" Opacity="0.45"/>
                    </Border.Shadow>
                    <Button x:Name="LoginBtn" BackgroundColor="Transparent"
                            TextColor="White" HeightRequest="56"
                            FontSize="16" FontAttributes="Bold"/>
                </Border>

                <!-- Nút khách -->
                <Border StrokeThickness="1.5" Stroke="#EEF0F6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <SolidColorBrush Color="White"/>
                    </Border.Background>
                    <Button x:Name="GuestBtn" BackgroundColor="Transparent"
                            TextColor="#9AA5B4" HeightRequest="50" FontSize="15"/>
                </Border>

                <!-- Đăng ký -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,8,0,0">
                    <Label Text="Chưa có tài khoản?" TextColor="#9AA5B4"
                           FontSize="14" VerticalOptions="Center"/>
                    <Button x:Name="RegisterBtn" BackgroundColor="Transparent"
                            TextColor="#FF7043" FontSize="14" FontAttributes="Bold" Padding="4,0"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
