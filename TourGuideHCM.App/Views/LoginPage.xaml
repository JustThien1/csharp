<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideHCM.App.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">

            <!-- Logo -->
            <Label Text="🗺️" FontSize="64" HorizontalOptions="Center"/>

            <!-- Tiêu đề -->
            <Label x:Name="TitleLabel"
                   FontSize="26" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"/>

            <!-- Nút chuyển ngôn ngữ -->
            <Button x:Name="LangBtn"
                    Clicked="OnLangClicked"
                    BackgroundColor="Transparent"
                    TextColor="#1976D2"
                    FontSize="13"
                    HorizontalOptions="End"/>

            <!-- Username -->
            <Frame CornerRadius="12" Padding="0" BorderColor="#E0E0E0" HasShadow="False">
                <Entry x:Name="UsernameEntry"
                       Margin="12,0" HeightRequest="48"
                       BackgroundColor="Transparent"
                       ReturnType="Next"/>
            </Frame>

            <!-- Password -->
            <Frame CornerRadius="12" Padding="0" BorderColor="#E0E0E0" HasShadow="False">
                <Entry x:Name="PasswordEntry"
                       Margin="12,0" HeightRequest="48"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       ReturnType="Done"/>
            </Frame>

            <!-- Error -->
            <Label x:Name="ErrorLabel"
                   TextColor="#E53935" FontSize="13"
                   IsVisible="False" HorizontalOptions="Center"/>

            <!-- Loading -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False" IsVisible="False"
                               Color="#1976D2"/>

            <!-- Login -->
            <Button x:Name="LoginBtn"
                    BackgroundColor="#1976D2" TextColor="White"
                    CornerRadius="12" HeightRequest="50" FontSize="16"/>

            <!-- Guest -->
            <Button x:Name="GuestBtn"
                    BackgroundColor="Transparent"
                    TextColor="#1976D2"
                    BorderColor="#1976D2" BorderWidth="1"
                    CornerRadius="12" HeightRequest="50" FontSize="15"/>

            <!-- Register -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Button x:Name="RegisterBtn"
                        BackgroundColor="Transparent"
                        TextColor="#1976D2"
                        FontSize="14" Padding="0"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
