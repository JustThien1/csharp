<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TourGuideHCM.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TourGuideHCM.App.Views"
    Title="TourGuide HCM"
    FlyoutBehavior="Flyout">

    <!-- HomePage là trang mặc định -->
    <FlyoutItem Route="HomePage" FlyoutItemIsVisible="False">
        <ShellContent 
            ContentTemplate="{DataTemplate views:HomePage}"
            Route="HomePage" />
    </FlyoutItem>

    <FlyoutItem Route="MapPage" FlyoutItemIsVisible="False">
        <ShellContent 
            ContentTemplate="{DataTemplate views:MapPage}"
            Route="MapPage" />
    </FlyoutItem>

    <FlyoutItem Route="PoiListPage" FlyoutItemIsVisible="False">
        <ShellContent 
            ContentTemplate="{DataTemplate views:PoiListPage}"
            Route="PoiListPage" />
    </FlyoutItem>

    <!-- Flyout Header -->
    <Shell.FlyoutHeader>
        <Grid HeightRequest="110" Padding="20,0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF6B6B" Offset="0"/>
                    <GradientStop Color="#FF8E53" Offset="0.5"/>
                    <GradientStop Color="#FFB347" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <HorizontalStackLayout VerticalOptions="Center" Spacing="12">
                <Border WidthRequest="44" HeightRequest="44" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <SolidColorBrush Color="#FFFFFF30"/>
                    </Border.Background>
                    <Label Text="🗺️" FontSize="22"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label Text="TourGuide HCM" TextColor="White"
                           FontSize="17" FontAttributes="Bold"/>
                    <Label Text="Khám phá Sài Gòn" TextColor="#FFFFFF99" FontSize="12"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <!-- Flyout Content -->
    <Shell.FlyoutContent>
        <Grid RowDefinitions="*,Auto" BackgroundColor="#FAFBFF">

            <!-- Danh sách POI nổi bật -->
            <CollectionView Grid.Row="0"
                            x:Name="PoiFlyoutList"
                            SelectionMode="Single"
                            SelectionChanged="OnPoiFlyoutSelected"
                            BackgroundColor="Transparent"
                            Margin="0,8">
                <CollectionView.Header>
                    <Label Text="ĐỊA ĐIỂM NỔI BẬT"
                           TextColor="#FF6B6B" FontSize="11" FontAttributes="Bold"
                           Margin="16,10,16,6" CharacterSpacing="1.5"/>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="12,4" StrokeThickness="1"
                                Stroke="#EEF0F6" Padding="14,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Border.Background>
                                <SolidColorBrush Color="White"/>
                            </Border.Background>
                            <Border.Shadow>
                                <Shadow Brush="#15000000" Offset="0,2" Radius="8" Opacity="0.1"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Border Grid.Column="0" WidthRequest="4" VerticalOptions="Fill"
                                        StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="2"/>
                                    </Border.StrokeShape>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF6B6B" Offset="0"/>
                                            <GradientStop Color="#FFA040" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="{Binding Name}" TextColor="#1A1A2E"
                                           FontSize="15" FontAttributes="Bold"/>
                                    <Label Text="{Binding Description}" TextColor="#9AA5B4"
                                           FontSize="12" LineBreakMode="TailTruncation" MaxLines="2"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Menu dưới -->
            <VerticalStackLayout Grid.Row="1" Spacing="0"
                                 Padding="0,8,0,16" BackgroundColor="White">
                <BoxView HeightRequest="1" Color="#EEF0F6"/>

                <Button Text="🏠   Trang chủ" BackgroundColor="Transparent"
                        TextColor="#1A1A2E" FontSize="15" HorizontalOptions="Fill"
                        ContentLayout="Left,14" Padding="20,14" Clicked="OnHomeClicked"/>

                <BoxView HeightRequest="1" Margin="20,0" Color="#EEF0F6"/>

                <Button Text="🗺️   Bản đồ" BackgroundColor="Transparent"
                        TextColor="#1A1A2E" FontSize="15" HorizontalOptions="Fill"
                        ContentLayout="Left,14" Padding="20,14" Clicked="OnMapClicked"/>

                <BoxView HeightRequest="1" Margin="20,0" Color="#EEF0F6"/>

                <Button Text="📋   Danh sách POI" BackgroundColor="Transparent"
                        TextColor="#1A1A2E" FontSize="15" HorizontalOptions="Fill"
                        ContentLayout="Left,14" Padding="20,14" Clicked="OnPoiListClicked"/>

            </VerticalStackLayout>

        </Grid>
    </Shell.FlyoutContent>

</Shell>
