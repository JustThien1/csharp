<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TourGuideHCM.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TourGuideHCM.App.Views"
    Title="TourGuideHCM">

    <!-- 📍 Menu chính -->
    <FlyoutItem Title="Bản đồ">
        <ShellContent
            Title="Map"
            ContentTemplate="{DataTemplate views:MapPage}" />
    </FlyoutItem>

    <!-- 🚪 Logout -->
    <MenuItem
        Text="Đăng xuất"
        Clicked="OnLogoutClicked" />

</Shell>